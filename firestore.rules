rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function userData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return signedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && userData().role == 'admin';
    }

    function isManager() {
      return signedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && userData().role == 'manager';
    }

    // teamMembers documents are created with the ID "<teamId>_<uid>" (see api/index.js),
    // so this helper now resolves correctly.
    function isTeamMember(teamId) {
      return signedIn()
        && exists(/databases/$(database)/documents/teamMembers/$(teamId + '_' + request.auth.uid));
    }

    function isTeamLead(teamId) {
      return signedIn()
        && exists(/databases/$(database)/documents/teamMembers/$(teamId + '_' + request.auth.uid))
        && get(/databases/$(database)/documents/teamMembers/$(teamId + '_' + request.auth.uid)).data.role == 'team_lead';
    }

    function isTeamCreator(teamId) {
      return signedIn()
        && exists(/databases/$(database)/documents/teams/$(teamId))
        && get(/databases/$(database)/documents/teams/$(teamId)).data.createdByUserId == request.auth.uid;
    }

    match /users/{userId} {
      allow read: if signedIn();
      allow create: if isAdmin() || (signedIn() && request.auth.uid == userId);
      allow update: if isAdmin() || (signedIn() && request.auth.uid == userId);
      allow delete: if isAdmin();
    }

    match /teams/{teamId} {
      allow read: if signedIn();
      allow create: if isAdmin();
      allow update: if isAdmin() || isManager() || isTeamLead(teamId) || isTeamCreator(teamId);
      allow delete: if isAdmin();
    }

    match /teamMembers/{memberId} {
      // All membership writes go through the admin SDK (api/index.js), so client create is admin-only.
      allow read: if signedIn();
      allow create: if isAdmin();
      allow update: if isAdmin() || (signedIn() && isTeamLead(resource.data.teamId));
      allow delete: if isAdmin() || (signedIn() && isTeamLead(resource.data.teamId));
    }

    match /ideas/{ideaId} {
      allow read: if isAdmin() || isTeamMember(resource.data.teamId);
      allow create: if signedIn() && isTeamMember(request.resource.data.teamId);
      allow update: if isAdmin()
        || isTeamLead(resource.data.teamId)
        || (signedIn() && resource.data.createdByUserId == request.auth.uid);
      allow delete: if isAdmin() || isTeamLead(resource.data.teamId);
    }

    match /ideaComments/{commentId} {
      allow read: if isAdmin()
        || (signedIn()
            && exists(/databases/$(database)/documents/ideas/$(resource.data.ideaId))
            && isTeamMember(get(/databases/$(database)/documents/ideas/$(resource.data.ideaId)).data.teamId));
      allow create: if signedIn()
        && request.resource.data.userId == request.auth.uid
        && (isAdmin()
            || (exists(/databases/$(database)/documents/ideas/$(request.resource.data.ideaId))
                && isTeamMember(get(/databases/$(database)/documents/ideas/$(request.resource.data.ideaId)).data.teamId)));
      allow update, delete: if isAdmin() || (signedIn() && resource.data.userId == request.auth.uid);
    }

    match /chatMessages/{messageId} {
      allow read: if isAdmin() || isTeamMember(resource.data.teamId);
      allow create: if signedIn()
        && request.resource.data.teamId is string
        && request.resource.data.senderUserId == request.auth.uid
        && (isAdmin() || isTeamMember(request.resource.data.teamId));
      allow update, delete: if isAdmin()
        || isTeamLead(resource.data.teamId)
        || (signedIn() && resource.data.senderUserId == request.auth.uid);
    }

    match /notifications/{notificationId} {
      allow read, update: if isAdmin() || (signedIn() && resource.data.userId == request.auth.uid);
      allow create, delete: if isAdmin();
    }

    match /workspaceInvites/{inviteId} {
      allow read: if isAdmin()
        || (signedIn() && resource.data.inviteeUserId == request.auth.uid)
        || (signedIn() && isTeamLead(resource.data.teamId));
      allow write: if isAdmin() || isTeamLead(resource.data.teamId);
    }

    match /personalIdeas/{ideaId} {
      allow read, delete: if isAdmin() || (signedIn() && resource.data.userId == request.auth.uid);
      allow create: if isAdmin() || (signedIn() && request.resource.data.userId == request.auth.uid);
      allow update: if isAdmin() || (signedIn() && resource.data.userId == request.auth.uid);
    }

    match /tasks/{taskId} {
      allow read: if isAdmin() || isTeamMember(resource.data.teamId);
      allow write: if isAdmin() || isTeamLead(resource.data.teamId);
    }

    match /taskSubmissions/{submissionId} {
      allow read: if isAdmin() || isTeamMember(resource.data.teamId);
      allow write: if isAdmin() || isTeamMember(resource.data.teamId);
    }

    match /auditLogs/{logId} {
      allow read, write: if isAdmin();
    }

    match /reports/{reportId} {
      allow read: if isAdmin()
        || (signedIn() && resource.data.userId == request.auth.uid)
        || (signedIn() && isTeamLead(resource.data.teamId));
      allow create: if signedIn() && (isAdmin() || isTeamMember(resource.data.teamId));
      allow update: if isAdmin() || isTeamLead(resource.data.teamId);
      allow delete: if isAdmin() || isTeamLead(resource.data.teamId);
    }

    match /settings/{settingId} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }

    // --- Yangi kolleksiyalar (T1/T4/T6/T9/T11/T13/T16) ---
    match /featureFlags/{flagId} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }

    match /timeLogs/{logId} {
      allow read: if isAdmin() || isTeamMember(resource.data.teamId);
      allow create: if signedIn()
        && (isAdmin()
            || isTeamMember(request.resource.data.teamId)
            || (request.resource.data.userId == request.auth.uid));
      allow update, delete: if isAdmin();
    }

    match /templates/{templateId} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }

    match /presence/{uid} {
      allow read: if signedIn();
      allow write: if signedIn() && request.auth.uid == uid;
    }

    match /attachments/{attachmentId} {
      allow read: if isAdmin() || isTeamMember(resource.data.teamId);
      allow create: if signedIn() && (isAdmin() || isTeamMember(request.resource.data.teamId));
      allow update, delete: if isAdmin();
    }
  }
}
