rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return signedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isTeamMember(teamId) {
      return signedIn()
        && exists(/databases/$(database)/documents/teamMembers/$(teamId + '_' + request.auth.uid));
    }

    function isTeamLead(teamId) {
      return signedIn()
        && exists(/databases/$(database)/documents/teamMembers/$(teamId + '_' + request.auth.uid))
        && get(/databases/$(database)/documents/teamMembers/$(teamId + '_' + request.auth.uid)).data.role == 'team_lead';
    }

    function isTeamCreator(teamId) {
      return signedIn()
        && exists(/databases/$(database)/documents/teams/$(teamId))
        && get(/databases/$(database)/documents/teams/$(teamId)).data.createdByUserId == request.auth.uid;
    }

    function canReadIdea(ideaId) {
      return signedIn()
        && exists(/databases/$(database)/documents/ideas/$(ideaId))
        && (isAdmin() || isTeamMember(get(/databases/$(database)/documents/ideas/$(ideaId)).data.teamId));
    }

    match /users/{userId} {
      allow read: if signedIn();
      allow create: if isAdmin() || (signedIn() && request.auth.uid == userId);
      allow update: if isAdmin() || (signedIn() && request.auth.uid == userId);
      allow delete: if isAdmin();
    }

    match /teams/{teamId} {
      allow read: if isAdmin() || isTeamMember(teamId);
      allow create: if isAdmin();
      allow update: if isTeamLead(teamId);
      allow delete: if isAdmin();
    }

    match /teamMembers/{memberId} {
      allow read: if signedIn();
      allow create: if (isAdmin()
          && request.resource.data.role == 'team_lead'
          && request.resource.data.teamId is string
          && request.resource.data.userId is string)
        || (signedIn()
          && request.resource.data.teamId is string
          && request.resource.data.userId is string
          && request.resource.data.role == 'member'
          && isTeamLead(request.resource.data.teamId))
        || (signedIn()
          && request.resource.data.teamId is string
          && request.resource.data.userId == request.auth.uid
          && request.resource.data.role == 'team_lead'
          && isTeamCreator(request.resource.data.teamId));
      allow update: if (isAdmin()
          && request.resource.data.role == 'team_lead'
          && request.resource.data.teamId is string
          && request.resource.data.userId is string)
        || (signedIn()
          && resource.data.teamId is string
          && request.resource.data.role == 'member'
          && isTeamLead(resource.data.teamId));
      allow delete: if signedIn() && resource.data.teamId is string && isTeamLead(resource.data.teamId);
    }

    match /ideas/{ideaId} {
      allow read: if isAdmin() || (resource.data.teamId is string && isTeamMember(resource.data.teamId));
      allow create: if signedIn() && isTeamMember(request.resource.data.teamId);
      allow update: if isAdmin()
        || isTeamLead(resource.data.teamId)
        || (signedIn() && resource.data.createdByUserId == request.auth.uid);
      allow delete: if isAdmin() || isTeamLead(resource.data.teamId);
    }

    match /ideaComments/{commentId} {
      allow read: if canReadIdea(resource.data.ideaId);
      allow create: if signedIn()
        && request.resource.data.ideaId is string
        && request.resource.data.userId == request.auth.uid
        && canReadIdea(request.resource.data.ideaId);
      allow update, delete: if isAdmin()
        || (signedIn() && resource.data.userId == request.auth.uid);
    }

    match /chatMessages/{messageId} {
      allow read: if isAdmin() || isTeamMember(resource.data.teamId);
      allow create: if signedIn()
        && request.resource.data.teamId is string
        && request.resource.data.senderUserId == request.auth.uid
        && isTeamMember(request.resource.data.teamId);
      allow update, delete: if isAdmin()
        || isTeamLead(resource.data.teamId)
        || (signedIn() && resource.data.senderUserId == request.auth.uid);
    }

    match /notifications/{notificationId} {
      allow read, update: if isAdmin()
        || (signedIn() && resource.data.userId == request.auth.uid);
      allow create, delete: if isAdmin();
    }

    match /workspaceInvites/{inviteId} {
      allow read: if isAdmin()
        || (signedIn() && resource.data.inviteeUserId == request.auth.uid)
        || (signedIn() && resource.data.teamId is string && isTeamLead(resource.data.teamId));
      allow write: if isAdmin();
    }

    match /personalIdeas/{ideaId} {
      allow read, delete: if isAdmin()
        || (signedIn() && resource.data.userId == request.auth.uid);
      allow create: if isAdmin()
        || (signedIn() && request.resource.data.userId == request.auth.uid);
      allow update: if isAdmin()
        || (signedIn() && resource.data.userId == request.auth.uid);
    }

    match /tasks/{taskId} {
      allow read: if isAdmin() || isTeamMember(resource.data.teamId);
      allow write: if isAdmin();
    }

    match /taskSubmissions/{submissionId} {
      allow read: if isAdmin() || isTeamMember(resource.data.teamId);
      allow write: if isAdmin();
    }

    match /auditLogs/{logId} {
      allow read, write: if isAdmin();
    }

    match /settings/{settingId} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }
  }
}
