# =============================================================================
# MllyCore — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
# Express server: PORT=3000 (default). For Vercel deployment: set via Vercel Dashboard.
#
# Required variables (marked with ⚠️) must be set for the API to work.
# Optional variables (marked with ℹ️) enable additional features.
# =============================================================================

# ═════════════════════════════════════════════════════════════════════════════
# 🔥 FIREBASE SERVICE ACCOUNT (⚠️ Required)
# ═════════════════════════════════════════════════════════════════════════════
# Firebase Admin SDK uchun xizmat ko'rsatish hisobi (Service Account) JSON.
# Firebase Console → Project Settings → Service Accounts → Generate New Private Key
# JSON formatda yoki base64 kodlangan holda beriladi.
#
# Local development: JSON faylni serviceAccountKey.json deb nomlab, loyiha
#   ildiziga qo'ying (api/index.js avtomatik topadi).
# Vercel: JSON ni base64 kodlab, ushbu env ga o'rnating.
#
# Example (JSON format):
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"mllycore",...}
#
# Example (base64 format):
# FIREBASE_SERVICE_ACCOUNT_JSON=<base64-kodlangan-json>
FIREBASE_SERVICE_ACCOUNT_JSON=

# ═════════════════════════════════════════════════════════════════════════════
# 🐙 GITHUB_TOKEN (⚠️ Required for T31 — GitHub Issues Sync)
# ═════════════════════════════════════════════════════════════════════════════
# GitHub Personal Access Token (classic yoki fine-grained).
# T31 (GitHub Issues Sync) vazifani GitHub Issues ga issue sifatida yaratish
# uchun ishlatiladi. Agar foydalanuvchi o'z tokenini kiritmasa, shu env
# ishlatiladi (fallback).
#
# Minimal ruxsatlar (fine-grained): "Issues: Read and Write"
# Classic token: repo sozlamalarida "public_repo" (public repo uchun) yoki
#   to'liq "repo" skop (private repo uchun).
#
# Yaratish: https://github.com/settings/tokens → Generate new token (classic)
#   → Select scopes: public_repo (yoki repo) → Generate → Copy token
#
# Example:
# GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GITHUB_TOKEN=

# ═════════════════════════════════════════════════════════════════════════════
# 🤖 TELEGRAM_BOT_TOKEN (ℹ️ Optional — T22 Telegram notifications)
# ═════════════════════════════════════════════════════════════════════════════
# Telegram bot token. @BotFather orqali bot yaratib oling.
# T22 (Telegram notifications) va T53 (Weekly Report) uchun ishlatiladi.
#
# Example:
# TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklmNOPqrstUVwxyz
TELEGRAM_BOT_TOKEN=

# ═════════════════════════════════════════════════════════════════════════════
# 🌐 VERCEL CONFIGURATION (ℹ️ Optional — set by Vercel automatically)
# ═════════════════════════════════════════════════════════════════════════════
# VERCEL_REGION — serverless funksiya qaysi regionda ishlaydi (avtomatik)
# VERCEL_ENV — environment nomi (production, preview, development)
# =============================================================================

# ═════════════════════════════════════════════════════════════════════════════
# 📝 LOCAL DEVELOPMENT ONLY (Vercel'ga qo'yilmang)
# ═════════════════════════════════════════════════════════════════════════════
# Firebase Emulator sozlamalari (localda avtomatik)
# FIRESTORE_EMULATOR_HOST=localhost:8080
# FIREBASE_STORAGE_EMULATOR_HOST=localhost:9199
# FIREBASE_AUTH_EMULATOR_HOST=localhost:9099
# =============================================================================
