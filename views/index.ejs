<!DOCTYPE html>
<html lang="uz" style="scroll-behavior:smooth">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>MllyCore — Startup workspace platformasi</title>
  <meta name="description" content="MllyCore — Admin, Team Lead va Member rollari bilan startup workspace oqimini bitta joyda tartibga soling.">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@500;600;700;800&family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
  <link rel="icon" type="image/svg+xml" href="images/favicon.svg">
  <link rel="apple-touch-icon" href="images/favicon.svg">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="theme-color" content="#0f172a">
  <link rel="stylesheet" href="css/styles.css">
  <link rel="manifest" href="manifest.webmanifest">
  <script src="js/icons.js"></script>
  <style>
    /* ===== Design Tokens ===== */
    :root {
      --landing-max-w: 1240px;
      --gradient-primary: linear-gradient(135deg, #2f81f7, #7c5cfc);
      --gradient-hero: linear-gradient(120deg, #f0f6ff 0%, #c4b5fd 42%, #a5b4fc 100%);
      --glow-blue: rgba(47,129,247,0.15);
      --glow-purple: rgba(124,92,252,0.12);
      --surface-card: rgba(12,20,36,0.72);
      --surface-glass: rgba(8,11,18,0.60);
    }
    body.theme-light {
      --glow-blue: rgba(9,105,218,0.08);
      --glow-purple: rgba(130,80,223,0.06);
      --surface-card: rgba(255,255,255,0.85);
      --surface-glass: rgba(248,250,255,0.82);
    }

    /* ===== Scroll Progress ===== */
    #scrollProgress {
      position: fixed; top: 0; left: 0;
      height: 2px;
      background: var(--gradient-primary);
      z-index: 9999; width: 0%;
      transition: width 60ms linear;
    }

    /* ===== Loader ===== */
    .page-loader {
      position: fixed; inset: 0; z-index: 99999;
      background: #080b12;
      display: flex; align-items: center; justify-content: center;
      flex-direction: column; gap: 20px;
      transition: opacity 0.5s ease, visibility 0.5s ease;
    }
    body.theme-light .page-loader { background: #ffffff; }
    .page-loader.hidden { opacity: 0; visibility: hidden; pointer-events: none; }
    .loader-ring {
      width: 56px; height: 56px;
      border-radius: 50%;
      border: 3px solid rgba(47,129,247,0.12);
      border-top-color: #2f81f7;
      animation: loaderSpin 0.8s linear infinite;
    }
    @keyframes loaderSpin { to { transform: rotate(360deg); } }

    /* ===== Floating Particles ===== */
    .particles {
      position: fixed; inset: 0;
      pointer-events: none; z-index: 0;
      overflow: hidden;
    }
    .particle {
      position: absolute;
      width: 4px; height: 4px;
      background: rgba(47,129,247,0.25);
      border-radius: 50%;
      animation: particleFloat linear infinite;
    }
    @keyframes particleFloat {
      0% { transform: translateY(100vh) scale(0); opacity: 0; }
      10% { opacity: 1; }
      90% { opacity: 1; }
      100% { transform: translateY(-10vh) scale(1); opacity: 0; }
    }

    /* ===== Navigation (sticky + mobile) ===== */
    .landing-nav {
      position: sticky; top: 0; z-index: 100;
      width: min(var(--landing-max-w), calc(100% - 40px));
      margin: 0 auto; padding: 18px 0;
      display: flex; align-items: center; justify-content: space-between; gap: 18px;
      transition: background 0.3s ease, box-shadow 0.3s ease, backdrop-filter 0.3s ease, padding 0.3s ease;
      border-radius: 0 0 18px 18px;
    }
    .landing-nav.scrolled {
      background: var(--surface-glass);
      backdrop-filter: blur(18px) saturate(1.4);
      box-shadow: 0 1px 0 rgba(148,163,184,0.10), 0 8px 32px rgba(2,6,23,0.25);
      padding: 10px 20px;
      width: min(calc(var(--landing-max-w) - 20px), calc(100% - 28px));
      border: 1px solid rgba(148,163,184,0.10);
      margin-top: 8px; border-radius: 16px;
    }
    body.theme-light .landing-nav.scrolled {
      background: rgba(248,250,255,0.88);
      box-shadow: 0 1px 0 rgba(148,163,184,0.10), 0 8px 32px rgba(148,163,184,0.10);
    }
    .nav-overlay {
      display: none;
      position: fixed; inset: 0; z-index: 99;
      background: rgba(2,6,15,0.6);
    }
    .nav-overlay.open { display: block; }

    /* Hamburger */
    .hamburger {
      display: none; flex-direction: column; gap: 5px;
      background: none; border: none; cursor: pointer;
      padding: 8px; border-radius: 10px;
      background: rgba(255,255,255,0.04);
      border: 1px solid rgba(148,163,184,0.12);
      position: relative; z-index: 101;
    }
    .hamburger span {
      display: block; width: 22px; height: 2px;
      background: var(--text, #e6edf3);
      border-radius: 2px;
      transition: transform 0.2s ease, opacity 0.2s ease;
    }
    .hamburger.open span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
    .hamburger.open span:nth-child(2) { opacity: 0; }
    .hamburger.open span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }
    body.theme-light .hamburger span { background: #1f2328; }

    /* ===== Hero ===== */
    .landing-hero {
      display: grid;
      grid-template-columns: minmax(0, 1.05fr) minmax(420px, 0.95fr);
      gap: 40px; align-items: center;
      padding: 72px 0 44px;
      position: relative;
    }
    .hero-glow-1 {
      position: absolute; top: -10%; left: -8%;
      width: 55%; height: 55%;
      background: radial-gradient(circle at 30% 40%, rgba(47,129,247,0.15), transparent 70%);
      filter: blur(80px); pointer-events: none; z-index: -1;
    }
    .hero-glow-2 {
      position: absolute; bottom: 5%; right: -5%;
      width: 40%; height: 40%;
      background: radial-gradient(circle at 50% 50%, rgba(124,92,252,0.10), transparent 65%);
      filter: blur(70px); pointer-events: none; z-index: -1;
    }
    .hero-float-el {
      position: absolute;
      border-radius: 12px;
      background: rgba(47,129,247,0.06);
      border: 1px solid rgba(47,129,247,0.12);
      backdrop-filter: blur(4px);
      padding: 10px 14px;
      font-size: 12px;
      color: var(--muted, #8b949e);
      animation: floatElement 4s ease-in-out infinite;
      pointer-events: none;
    }
    .hero-float-el:nth-child(2) { top: 12%; right: 8%; animation-delay: -1s; }
    .hero-float-el:nth-child(3) { bottom: 18%; left: 3%; animation-delay: -2.5s; }
    @keyframes floatElement {
      0%, 100% { transform: translateY(0); }
      50% { transform: translateY(-8px); }
    }

    .landing-copy h1 {
      margin: 18px 0;
      font-family: 'Space Grotesk', sans-serif;
      font-size: clamp(48px, 6.2vw, 78px);
      line-height: 0.99;
      letter-spacing: -0.025em;
      max-width: 14ch;
      background: var(--gradient-hero);
      -webkit-background-clip: text; background-clip: text;
      -webkit-text-fill-color: transparent; color: transparent;
      animation: heroTextReveal 0.8s cubic-bezier(0.22, 1, 0.36, 1) both 0.15s;
    }
    @keyframes heroTextReveal {
      from { opacity: 0; transform: translateY(20px) scale(0.96); }
      to   { opacity: 1; transform: translateY(0) scale(1); }
    }
    body.theme-light .landing-copy h1 {
      background: linear-gradient(120deg, #1f2328 0%, #8250df 50%, #0969da 100%);
      -webkit-background-clip: text; background-clip: text;
      -webkit-text-fill-color: transparent; color: transparent;
    }
    .landing-copy .highlight-text {
      background: linear-gradient(135deg,#2f81f7,#7c5cfc,#ec4899);
      -webkit-background-clip: text; background-clip: text;
      -webkit-text-fill-color: transparent;
    }

    /* Pill row */
    .landing-pill-row {
      display: flex; gap: 10px; flex-wrap: wrap; margin-bottom: 6px;
      animation: fadeUp 0.6s cubic-bezier(0.22, 1, 0.36, 1) both 0.05s;
    }
    .pill-interactive {
      display: inline-flex; align-items: center; gap: 8px;
      padding: 7px 14px; border-radius: 999px;
      background: rgba(47,129,247,0.10);
      border: 1px solid rgba(47,129,247,0.20);
      color: #79c0ff; font-size: 13px; font-weight: 600;
      transition: all 0.2s ease, transform 0.15s cubic-bezier(0.34,1.56,0.64,1);
      cursor: default;
    }
    .pill-interactive:hover {
      background: rgba(47,129,247,0.18);
      border-color: rgba(47,129,247,0.35);
      transform: translateY(-1px);
    }
    body.theme-light .pill-interactive {
      background: rgba(9,105,218,0.08);
      border-color: rgba(9,105,218,0.18); color: #0969da;
    }
    .pill-dot { width: 7px; height: 7px; border-radius: 50%; background: #3fb950; animation: pulseDot 2s ease-in-out infinite; }
    @keyframes pulseDot { 0%,100% { opacity:1; transform:scale(1); } 50% { opacity:.6; transform:scale(.8); } }

    .landing-lead { animation: fadeUp 0.6s cubic-bezier(0.22, 1, 0.36, 1) both 0.30s; }
    .landing-actions { animation: fadeUp 0.6s cubic-bezier(0.22, 1, 0.36, 1) both 0.40s; }
    .landing-proof { animation: fadeUp 0.6s cubic-bezier(0.22, 1, 0.36, 1) both 0.50s; }
    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(14px); }
      to   { opacity: 1; transform: translateY(0); }
    }

    /* ===== Proof / Stats Counters ===== */
    .landing-proof {
      display: flex; gap: 14px; flex-wrap: wrap; margin-top: 32px;
    }
    .landing-proof-item {
      flex: 1; min-width: 140px;
      padding: 18px 20px;
      border-radius: 18px;
      background: var(--surface-card);
      border: 1px solid rgba(148,163,184,0.10);
      backdrop-filter: blur(4px);
      transition: transform 0.2s ease, border-color 0.2s ease;
    }
    .landing-proof-item:hover {
      transform: translateY(-2px);
      border-color: rgba(47,129,247,0.20);
    }
    .landing-proof-item strong {
      display: block; font-size: 24px; font-family: 'Space Grotesk', sans-serif;
      background: var(--gradient-primary);
      -webkit-background-clip: text; background-clip: text;
      -webkit-text-fill-color: transparent;
      margin-bottom: 4px;
    }
    .landing-proof-item span { color: var(--muted, #8b949e); font-size: 13px; }

    /* ===== Showcase ===== */
    .landing-showcase {
      position: relative; perspective: 1200px;
      animation: showcaseEnter 0.7s cubic-bezier(0.22, 1, 0.36, 1) 0.20s both;
    }
    @keyframes showcaseEnter {
      from { opacity:0; transform:translateY(16px) scale(0.96); }
      to   { opacity:1; transform:translateY(0) scale(1); }
    }
    .landing-showcase .landing-window {
      transform-style: preserve-3d; transition: transform 0.12s ease-out;
      will-change: transform;
    }
    .landing-showcase::before {
      content: "";
      position: absolute; inset: -12% -15% auto auto;
      width: 70%; height: 70%;
      background: radial-gradient(circle at 50% 50%, rgba(124,92,252,0.20), transparent 70%);
      filter: blur(72px); z-index: 0; pointer-events: none;
    }
    .landing-product-link {
      cursor: pointer; transition: all 0.2s ease; position: relative;
    }
    .landing-product-link::after {
      content: ''; position: absolute;
      left: 12px; right: 12px; bottom: 4px; height: 2px;
      background: var(--gradient-primary);
      border-radius: 4px; transform: scaleX(0);
      transition: transform 0.2s cubic-bezier(0.22, 1, 0.36, 1);
    }
    .landing-product-link:hover::after,
    .landing-product-link.active::after { transform: scaleX(1); }

    /* ===== Reveal Animation ===== */
    .reveal {
      opacity: 0; transform: translateY(28px);
      transition: opacity 0.7s cubic-bezier(0.22, 1, 0.36, 1),
                  transform 0.7s cubic-bezier(0.22, 1, 0.36, 1);
    }
    .reveal.visible { opacity: 1; transform: translateY(0); }
    .reveal-delay-1 { transition-delay: 0.05s; }
    .reveal-delay-2 { transition-delay: 0.10s; }
    .reveal-delay-3 { transition-delay: 0.15s; }
    .reveal-delay-4 { transition-delay: 0.20s; }
    .reveal-delay-5 { transition-delay: 0.25s; }
    .reveal-delay-6 { transition-delay: 0.30s; }
    .reveal-delay-7 { transition-delay: 0.35s; }

    /* ===== Stat Counter ===== */
    .stat-counter { display: inline-block; }

    /* ===== Sections ===== */
    .landing-strip {
      display: flex; gap: 10px; flex-wrap: wrap; padding: 0 0 24px;
    }
    .landing-strip-item {
      padding: 10px 16px; border-radius: 999px;
      background: rgba(255,255,255,0.03);
      color: var(--muted, #8b949e);
      border: 1px solid rgba(148,163,184,0.10);
      font-size: 13px; font-weight: 500;
      transition: all 0.2s ease;
    }
    .landing-strip-item:hover {
      background: rgba(47,129,247,0.08);
      border-color: rgba(47,129,247,0.20);
      color: #79c0ff;
    }

    /* Features Grid */
    .features-grid {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 16px;
      margin-top: 12px;
    }
    .feature-card {
      padding: 24px; border-radius: 20px;
      border: 1px solid rgba(148,163,184,0.10);
      background: var(--surface-card);
      backdrop-filter: blur(4px);
      transition: all 0.25s cubic-bezier(0.22, 1, 0.36, 1);
    }
    .feature-card:hover {
      transform: translateY(-4px);
      border-color: rgba(47,129,247,0.20);
      box-shadow: 0 20px 50px rgba(2,6,23,0.25);
    }
    .feature-icon {
      width: 48px; height: 48px; border-radius: 14px;
      display: flex; align-items: center; justify-content: center;
      font-size: 22px; margin-bottom: 16px;
      background: rgba(47,129,247,0.10);
      border: 1px solid rgba(47,129,247,0.15);
    }
    .feature-card h3 { margin: 0 0 8px; font-size: 18px; font-family: 'Space Grotesk', sans-serif; }
    .feature-card p { margin: 0; color: var(--muted, #8b949e); font-size: 14px; line-height: 1.7; }
    .feature-tag {
      display: inline-block; margin-top: 14px;
      padding: 4px 10px; border-radius: 999px;
      background: rgba(63,185,80,0.10);
      border: 1px solid rgba(63,185,80,0.20);
      color: #7ee787; font-size: 11px; font-weight: 600;
    }

    /* Workflow — Timeline style */
    .workflow-timeline {
      position: relative;
      display: grid; grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 20px;
    }
    .workflow-timeline::before {
      content: '';
      position: absolute;
      top: 48px; left: 15%; right: 15%;
      height: 2px;
      background: linear-gradient(90deg, rgba(47,129,247,0.08), rgba(124,92,252,0.16), rgba(47,129,247,0.08));
      z-index: 0;
    }
    .wf-card {
      position: relative; z-index: 1;
      padding: 24px; border-radius: 20px;
      border: 1px solid rgba(148,163,184,0.10);
      background: var(--surface-card);
      backdrop-filter: blur(4px);
      transition: transform 0.25s ease, border-color 0.25s ease;
    }
    .wf-card:hover {
      transform: translateY(-3px);
      border-color: rgba(124,92,252,0.20);
    }
    .wf-step {
      display: inline-flex; align-items: center; justify-content: center;
      width: 44px; height: 44px; border-radius: 14px;
      background: var(--gradient-primary);
      color: #fff; font-weight: 800; font-size: 16px;
      font-family: 'Space Grotesk', sans-serif;
      margin-bottom: 14px;
    }
    .wf-card h3 { margin: 0 0 8px; font-size: 20px; font-family: 'Space Grotesk', sans-serif; }
    .wf-card p { margin: 0; color: var(--muted, #8b949e); font-size: 14px; line-height: 1.7; }

    /* Role cards */
    .role-grid {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 16px;
    }
    .role-card {
      padding: 28px; border-radius: 20px;
      border: 1px solid rgba(148,163,184,0.10);
      background: var(--surface-card);
      backdrop-filter: blur(4px);
      transition: transform 0.25s ease, border-color 0.25s ease;
    }
    .role-card:hover { transform: translateY(-3px); border-color: rgba(47,129,247,0.18); }
    .role-card.featured {
      border-color: rgba(124,92,252,0.20);
      background: linear-gradient(180deg, rgba(124,92,252,0.06), var(--surface-card));
    }
    .role-card .role-badge {
      display: inline-block; padding: 5px 12px; border-radius: 999px;
      font-size: 12px; font-weight: 700; margin-bottom: 14px;
    }
    .role-badge.admin { background: rgba(47,129,247,0.12); color: #79c0ff; border: 1px solid rgba(47,129,247,0.20); }
    .role-badge.lead { background: rgba(124,92,252,0.12); color: #c4b5fd; border: 1px solid rgba(124,92,252,0.20); }
    .role-badge.member { background: rgba(210,153,34,0.12); color: #d29922; border: 1px solid rgba(210,153,34,0.20); }
    .role-card strong { display: block; font-size: 20px; font-family: 'Space Grotesk', sans-serif; margin-bottom: 8px; }
    .role-card p { color: var(--muted, #8b949e); font-size: 14px; line-height: 1.7; margin: 0; }

    /* ===== FAQ ===== */
    .faq-list { display: grid; gap: 10px; }
    .faq-item {
      border: 1px solid rgba(148,163,184,0.10);
      border-radius: 16px; overflow: hidden;
      background: var(--surface-card);
      backdrop-filter: blur(4px);
    }
    .faq-question {
      width: 100%; display: flex; align-items: center; justify-content: space-between;
      padding: 18px 20px; background: transparent; border: none;
      color: var(--text, #e6edf3); font-size: 15px; font-weight: 600;
      cursor: pointer; text-align: left; font-family: inherit;
      transition: background 0.15s ease;
    }
    .faq-question:hover { background: rgba(47,129,247,0.04); }
    .faq-question .faq-icon {
      transition: transform 0.2s ease; color: var(--muted, #8b949e);
      font-size: 18px; flex-shrink: 0;
    }
    .faq-item.open .faq-question .faq-icon { transform: rotate(45deg); }
    .faq-body {
      display: none; padding: 0 20px 18px;
      color: var(--muted, #8b949e); font-size: 14px; line-height: 1.7;
    }
    .faq-item.open .faq-body {
      display: block; animation: faqIn 0.18s ease;
    }
    @keyframes faqIn { from { opacity: 0; transform: translateY(-4px); } to { opacity: 1; transform: none; } }

    /* ===== Footer ===== */
    .landing-footer {
      border-top: 1px solid rgba(148,163,184,0.08);
      padding: 40px 0 28px;
      margin-top: 20px;
    }
    .footer-grid {
      display: grid;
      grid-template-columns: 2fr 1fr 1fr 1fr;
      gap: 30px;
      margin-bottom: 28px;
    }
    .footer-col h4 {
      font-family: 'Space Grotesk', sans-serif;
      font-size: 14px; margin: 0 0 14px;
    }
    .footer-col p { color: var(--muted, #8b949e); font-size: 13px; line-height: 1.7; margin: 0; }
    .footer-col a {
      display: block; color: var(--muted, #8b949e);
      font-size: 13px; padding: 4px 0;
      transition: color 0.15s ease;
    }
    .footer-col a:hover { color: var(--text, #e6edf3); }
    .footer-bottom {
      border-top: 1px solid rgba(148,163,184,0.06);
      padding-top: 18px;
      display: flex; justify-content: space-between; align-items: center;
      flex-wrap: wrap; gap: 10px;
    }
    .footer-bottom span { color: var(--muted, #8b949e); font-size: 12px; }
    .social-links { display: flex; gap: 10px; }
    .social-links a {
      width: 36px; height: 36px; border-radius: 10px;
      display: inline-flex; align-items: center; justify-content: center;
      background: rgba(255,255,255,0.03);
      border: 1px solid rgba(148,163,184,0.10);
      color: var(--muted, #8b949e); font-size: 14px;
      transition: all 0.15s ease; text-decoration: none;
    }
    .social-links a:hover {
      background: rgba(47,129,247,0.10);
      border-color: rgba(47,129,247,0.20);
      color: #79c0ff;
    }

    /* ===== Responsive ===== */
    @media (max-width: 1100px) {
      .landing-hero,
      .features-grid,
      .workflow-timeline,
      .role-grid { grid-template-columns: 1fr; }
      .landing-hero { padding: 38px 0 28px; }
      .footer-grid { grid-template-columns: 1fr 1fr; }
      .workflow-timeline::before { display: none; }
    }
    @media (max-width: 840px) {
      .hamburger { display: flex; }
      .landing-nav-links,
      .landing-nav-actions { display: none; }
      .landing-nav-links.open,
      .landing-nav-actions.open { display: flex; }
      .landing-nav-links.open {
        position: fixed; top: 0; right: 0; z-index: 100;
        flex-direction: column; width: 280px; height: 100vh;
        background: var(--surface-glass);
        backdrop-filter: blur(20px);
        padding: 80px 24px 24px;
        border-left: 1px solid rgba(148,163,184,0.10);
        animation: slideInRight 0.2s ease;
      }
      .landing-nav-links.closing {
        animation: slideOutRight 0.18s ease forwards;
      }
      .landing-nav-actions.open {
        position: fixed; bottom: 24px; right: 24px; z-index: 101;
        flex-direction: column; width: 232px;
      }
      @keyframes slideInRight { from { transform:translateX(100%); } to { transform:translateX(0); } }
      @keyframes slideOutRight { from { transform:translateX(0); } to { transform:translateX(100%); } }
      .landing-nav.scrolled .hamburger { background: rgba(255,255,255,0.06); }
    }
    @media (max-width: 700px) {
      .landing-nav.scrolled { padding: 10px 14px; }
      .footer-grid { grid-template-columns: 1fr; }
      .features-grid { gap: 12px; }
