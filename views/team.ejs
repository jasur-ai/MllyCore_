<!DOCTYPE html>
<html lang="uz" class="auth-required">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Workspace - MllyCore</title>
  <!-- Xavfsizlik: JS yuklanmasa ham 20 soniyadan keyin avtomatik qayta yuklash -->
  <link rel="icon" type="image/svg+xml" href="images/favicon.svg">
  <link rel="apple-touch-icon" href="images/favicon.svg">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <link rel="manifest" href="manifest.webmanifest">
  <meta name="theme-color" content="#0f172a">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="css/styles.css">
  
  <script>(function(){try{var s=localStorage.getItem('mllycore-theme')||'dark';document.documentElement.className=s==='light'?'theme-light':'theme-dark'}catch(_){document.documentElement.className='theme-dark';}})();</script>
</head>
<body>
  <a href="#content" class="skip-link">Asosiy kontentga o'tish</a>
  <div id="app">
    <div id="content" class="workspace-app" role="main" tabindex="-1" aria-label="Workspace asosiy kontenti"><div class="workspace-empty loading-copy"><h3>Yuklanmoqda...</h3><p>Workspace tayyorlanmoqda.</p></div></div>
  </div>
  <script src="js/theme.js"></script>
  <script src="js/firebase-config.js"></script>
  
  <script src="js/firebase-service.js"></script>
  <script src="js/auth-guard.js"></script>
  <script src="js/layout.js"></script>
  <script>
    // JavaScript ishlayapti — meta refreshni to'xtatamiz (agar mavjud bo'lsa)
    (function() {
      var meta = document.getElementById('metaHardTimeout');
      if (meta) { meta.content = ''; meta.parentNode.removeChild(meta); }
    })();
    // retry=1 bilan qayta yuklanganda — to'g'ridan-to'g'ri xato ko'rsatamiz
    if (location.search.indexOf('retry=1') !== -1) {
      document.getElementById('content').innerHTML = '<div class="workspace-empty"><h3>Yuklashda vaqt o\'tdi</h3><p>Sahifa avtomatik qayta yuklandi, ammo ma\'lumotlarni yuklashda davomiy muammo bor. Internet aloqangizni tekshiring.</p><button class="btn btn-primary" onclick="location.href=\'team.html\'">🔄 Qayta urinish</button></div>';
      window.__mllyLoadingTimeout && clearTimeout(window.__mllyLoadingTimeout);
      window.__mllyFallbackReload && clearTimeout(window.__mllyFallbackReload);
      window.__mllyLoadingTimeout = null;
      window.__mllyFallbackReload = null;
    }

    const qs = (key) => new URLSearchParams(location.search).get(key);
    const escapeHtml = (value) => String(value || '').replace(/[&<>"']/g, (char) => ({
      '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#039;'
    }[char]));
    const nameOf = (m, members) => {
      const mem = (members || []).find((mm) => mm.userId === m.userId);
      return (mem && (mem.user?.name || mem.user?.email)) || m.name || m.userId || 'A’zo';
    };
    const fmtDate = (value) => {
      if (!value) return '-';
      const date = value.toDate ? value.toDate() : new Date(value);
      return Number.isNaN(date.getTime()) ? '-' : date.toLocaleString('uz-UZ');
    };
    const fmtDateInput = (value) => {
      if (!value) return '';
      const date = new Date(value);
      return Number.isNaN(date.getTime()) ? '' : date.toISOString().slice(0, 16);
    };
    const focusType = qs('focus');
    const focusEntityId = qs('entity');

    // Xavfsizlik: 15 soniya ichida yuklanmasa, Yuklanmoqda matnini xato xabariga almashtiramiz
    window.__mllyLoadingTimeout = setTimeout(() => {
      const el = document.getElementById('content');
      if (!el || !el.querySelector('.loading-copy')) return;
      el.innerHTML = '<div class=\'workspace-empty\'><h3>Yuklashda xatolik</h3><p>Sahifa uzoq vaqt yuklanmadi. Internet aloqangizni tekshiring yoki qayta urinib ko\'ring.</p><button class="btn btn-primary btn-sm" onclick="location.reload()">🔄 Qayta urinish</button></div>';
    }, 15000);
    // Agar renderWorkspace muvaffaqiyatli bajarilsa, bu timeoutni tozalaymiz
    window.__clearLoadingTimeout = () => { if (window.__mllyLoadingTimeout) { clearTimeout(window.__mllyLoadingTimeout); window.__mllyLoadingTimeout = null; } };
    // Xavfsizlik: 30 soniya ichida hali ham yuklanmasa, avtomatik qayta yuklaymiz
    window.__mllyFallbackReload = setTimeout(() => {
      const el = document.getElementById("content");
      if (el && el.querySelector('.loading-copy')) {
        location.reload();
      }
    }, 30000);
    window.__clearFallbackReload = () => { if (window.__mllyFallbackReload) { clearTimeout(window.__mllyFallbackReload); window.__mllyFallbackReload = null; } };
    

    window.UTIL = window.UTIL || {
      toast: (msg) => {
        const el = document.createElement('div');
        el.className = 'toast';
        el.textContent = msg;
        document.body.appendChild(el);
        requestAnimationFrame(() => el.classList.add('show'));
        setTimeout(() => {
          el.classList.remove('show');
          setTimeout(() => el.remove(), 250);
        }, 2200);
      }
    };

    let chatUnsubscribe = null;
    let presenceUnsubs = [];
    let workspaceState = null;
    let chatSeenTimer = null;
    let chatSubscribedTeamId = '';
    let lastWorkspaceRenderKey = '';
    let _presenceVisibilityHandler = null;
    
    // FIX (presenceUnsubs cleanup): barcha presence obunalarini xavfsiz tozalash
    function _cleanupPresence() {
      if (presenceUnsubs.length) {
        for (var i = 0; i < presenceUnsubs.length; i++) {
          try { if (typeof presenceUnsubs[i] === 'function') presenceUnsubs[i](); } catch (_) {}
        }
        presenceUnsubs = [];
      }
      if (_presenceVisibilityHandler) {
        document.removeEventListener('visibilitychange', _presenceVisibilityHandler);
        _presenceVisibilityHandler = null;
      }
    }

    function setFeedback(id, text, tone = 'error') {
      const node = document.getElementById(id);
      if (!node) return;
      node.className = `text-sm muted feedback-${tone}`;
      node.textContent = text || '';
    }

    function workspaceRenderKey(data) {
      if (!data?.team?.id) return '';
      const latestIdea = (data.ideas || [])[0];
      const latestTask = (data.tasks || [])[0];
      const latestSubmission = (data.taskSubmissions || [])[0];
      const latestMessage = (data.messages || []).length ? data.messages[data.messages.length - 1] : null;
      return [
        data.team.id,
        data.members?.length || 0,
        data.ideas?.length || 0,
        data.tasks?.length || 0,
        data.taskSubmissions?.length || 0,
        data.messages?.length || 0,
        latestIdea?.id || '',
        latestTask?.id || '',
        latestSubmission?.id || '',
        latestMessage?.id || '',
        latestMessage?.seenBy?.length || 0,
        data.team.updatedAt?.seconds || data.team.updatedAt || ''
      ].join('|');
    }

    function memberOptions(members, includeLead = true) {
      return members
        .filter((member) => includeLead || member.role !== 'team_lead')
        .map((member) => `<option value="${member.userId}">${escapeHtml(member.user?.name || member.user?.email || member.userId)}</option>`)
        .join('');
    }

    function renderChat(messages, currentUserId) {
      const target = document.getElementById('chatMessages');
      if (!target) return;
      target.innerHTML = messages.length ? messages.map((message) => `
        <div class="msg ${message.senderUserId === currentUserId ? 'me' : ''}" data-message-id="${message.id}">
          <div class="avatar-sm avatar">${escapeHtml(message.senderAvatar || 'U')}</div>
          <div class="bubble">
            <div class="meta">
              <span>${escapeHtml(message.senderName || 'User')} / ${fmtDate(message.createdAt || message.clientCreatedAt)}</span>
              ${message.senderUserId === currentUserId ? `<span class="chat-checks ${(Array.isArray(message.seenBy) && message.seenBy.length > 1) ? 'is-read' : ''}">${(Array.isArray(message.seenBy) && message.seenBy.length > 1) ? '\u2713\u2713' : '\u2713'}</span>` : ''}
            </div>
            <div>${escapeHtml(message.text)}</div>
          </div>
        </div>
      `).join('') : '<div class="chat-empty">Chat hali bo\'sh. Birinchi xabarni yozing.</div>';
      if (focusType === 'chat' && focusEntityId) {
        const focused = target.querySelector(`[data-message-id="${focusEntityId}"]`);
        if (focused) {
          focused.scrollIntoView({ behavior: 'smooth', block: 'center' });
          focused.classList.add('workspace-flash');
          setTimeout(() => focused.classList.remove('workspace-flash'), 1800);
        } else {
          target.scrollTop = target.scrollHeight;
        }
      } else {
        target.scrollTop = target.scrollHeight;
      }
      const count = document.getElementById('chatCount');
      if (count) count.textContent = messages.length;
      const stat = document.getElementById('chatStat');
      if (stat) stat.textContent = messages.length;
    }

    // FIX (chatSeen race condition): ketma-ket so'rovlarni queue'ga solamiz
    // va ularni serial (navbatma-navbat) yuboramiz. Agar ikkinchi so'rov kelsa,
    // birinchisi bekor qilinadi va faqat eng oxirgisi ishga tushadi.
    var _chatSeenQueue = [];
    var _chatSeenProcessing = false;

    async function _processChatSeenQueue() {
      if (_chatSeenProcessing) return;
      _chatSeenProcessing = true;
      while (_chatSeenQueue.length > 0) {
        var task = _chatSeenQueue.shift();
        try {
          await MllyCore.markTeamChatSeen(task.teamId);
        } catch (_) {}
      }
      _chatSeenProcessing = false;
    }

    function canMarkChatSeen() {
      var chatBox = document.getElementById('chatMessages');
      if (!chatBox) return false;
      var rect = chatBox.getBoundingClientRect();
      var visible = rect.bottom > 100 && rect.top < (window.innerHeight || document.documentElement.clientHeight) - 40;
      return document.visibilityState === 'visible' && document.hasFocus() && visible;
    }

    function scheduleChatSeen(messages, currentUserId, teamId) {
      // Queue'ga faqat bitta yozuv: avvalgisini tozalab, eng oxirgisini qo'shamiz
      if (_chatSeenQueue.length > 0) {
        _chatSeenQueue = []; // oldingi navbatni bekor qilish
      }
      var hasUnseen = (messages || []).some(function(message) {
        var seenBy = Array.isArray(message.seenBy) ? message.seenBy : [];
        return message.senderUserId !== currentUserId && !seenBy.includes(currentUserId);
      });
      if (!hasUnseen || !teamId || !canMarkChatSeen()) return;
      
      _chatSeenQueue.push({ teamId: teamId });
      // 800ms debounce — bu vaqt ichida yana bir xabar kelsa, queue tozalanadi
      if (chatSeenTimer) clearTimeout(chatSeenTimer);
      chatSeenTimer = setTimeout(_processChatSeenQueue, 800);
    }

    async function markWorkspaceNotificationsSeen(data) {
      const ideaIds = (data.ideas || []).map((item) => item.id);
      const taskIds = (data.tasks || []).map((item) => item.id);
      const types = ['team_message', 'task_assigned', 'task_claimed', 'task_progress', 'task_completed', 'task_auto_assigned'];

      await MllyCore.markNotificationsRead({
        teamId: data.team.id,
        relatedEntityIds: taskIds,
        types: types.filter((type) => type !== 'team_message')
      }).catch(() => {});

      await MllyCore.markNotificationsRead({
        teamId: data.team.id,
        relatedEntityIds: ideaIds,
        types: ['idea_created', 'idea_imported', 'startup_created', 'startup_owner_changed']
      }).catch(() => {});

      await MllyCore.markNotificationsRead({
        teamId: data.team.id,
        types: ['team_message']
      }).catch(() => {});
    }

    function renderMembers(data, currentUserId, isLead, isManagerViewer) {
      const target = document.getElementById('membersList');
      if (!target) return;
      target.innerHTML = data.members.map((member) => `
        <div class="workspace-list-row">
          <div class="avatar" style="position:relative">${escapeHtml(member.user?.avatar || 'U')}<span class="presence-dot" id="presence-${member.userId}" title="offline" style="position:absolute;right:-2px;bottom:-2px;width:11px;height:11px;border-radius:50%;background:#64748b;border:2px solid var(--surface,#0f172a);"></span></div>
          <div class="workspace-list-copy">
            <strong>${escapeHtml(member.user?.name || member.user?.email || member.userId)}</strong>
            <span>@${escapeHtml(member.user?.username || 'user')} / ${escapeHtml(member.user?.email || '')}</span>
          </div>
          <div class="workspace-stack-tight" style="justify-items:end">
            <span class="badge ${member.role === 'team_lead' ? 'badge-active' : ''}">${escapeHtml(member.role)}</span>
            ${member.userId === currentUserId ? '<span class="workspace-pill-note">Bu siz</span>' : ''}
          </div>
          ${isLead && !isManagerViewer && member.userId !== currentUserId && member.role !== 'team_lead' ? `
          <div class="member-role-edit" style="display:flex;gap:6px;margin-top:8px;align-items:center;">
            <select class="select btn-sm" data-member-role="${member.userId}">
              <option value="member" ${member.role === 'member' ? 'selected' : ''}>Member (yozishi mumkin)</option>
              <option value="viewer" ${member.role === 'viewer' ? 'selected' : ''}>Viewer (faqat o'qiydi)</option>
            </select>
            <button class="btn btn-secondary btn-sm" data-member-role-save="${member.userId}">Rolni saqlash</button>
          </div>` : ''}
        </div>
      `).join('');
      document.querySelectorAll('[data-member-role-save]').forEach((button) => {
        button.addEventListener('click', async () => {
          const userId = button.dataset.memberRoleSave;
          const sel = document.querySelector('[data-member-role="' + userId + '"]');
          const role = sel ? sel.value : 'member';
          button.disabled = true;
          try {
            await MllyCore.updateMemberRole({ teamId: data.team.id, userId, role });
            UTIL.toast("A'zo roli yangilandi: " + role);
            await refreshWorkspace(data.team.id, currentUserId);
          } catch (error) {
            UTIL.toast(error.message || "Rol o'zgartirilmadi.");
            button.disabled = false;
          }
        });
      });
    }

    function renderEntries(data, currentUserId, isLead, isManagerViewer) {
      const ideas = data.ideas.filter((entry) => entry.entryType !== 'startup');
      const startups = data.ideas.filter((entry) => entry.entryType === 'startup');
      var _st = document.getElementById('ideaStat'); if (_st) _st.textContent = ideas.length;
      _st = document.getElementById('startupStat'); if (_st) _st.textContent = startups.length;
      var _ic = document.getElementById('ideasCount'); if (_ic) _ic.textContent = `${ideas.length} ta`;
      var _sc = document.getElementById('startupsCount'); if (_sc) _sc.textContent = `${startups.length} ta`;

      var _sl = document.getElementById('startupList'); if (!_sl) return;
      _sl.innerHTML = startups.length ? startups.map((item) => `
        <div class="workspace-record workspace-record-startup workspace-record-accent" data-startup-id="${item.id}">
          <div class="workspace-record-top">
            <div>
              <h3>${escapeHtml(item.title)}</h3>
              <div class="workspace-inline-meta">
                <span>Startup</span>
                <span>Mas'ul: ${escapeHtml(item.ownerName || 'Belgilanmagan')}</span>
              </div>
            </div>
            <span class="badge badge-active">${escapeHtml(item.status || 'Startup')}</span>
          </div>
          <p>${escapeHtml(item.description || 'Startup tafsiloti kiritilmagan.')}</p>
          ${isLead && !isManagerViewer ? `
            <div class="workspace-subgrid cols-2 mt-3">
              <select class="select" data-owner-select="${item.id}">
                <option value="">Mas'ul tanlang</option>
                ${memberOptions(data.members, true)}
              </select>
              <button class="btn btn-secondary" data-owner-save="${item.id}">Mas'ulni saqlash</button>
            </div>
            <div class="text-sm muted" data-owner-feedback="${item.id}"></div>
          ` : ''}
        </div>
      `).join('') : '<div class="workspace-empty"><h3>Startup yo\'q</h3><p>Hozircha team lead startup qo\'shmagan.</p></div>';

      document.getElementById('ideasList').innerHTML = ideas.length ? ideas.map((item) => `
        <a href="idea.html?id=${item.id}" class="workspace-record workspace-record-idea" data-idea-id="${item.id}">
          <div class="workspace-record-top">
            <div>
              <h3>${escapeHtml(item.title)}</h3>
              <div class="workspace-inline-meta">
                <span>G'oya</span>
                <span>Mas'ul: ${escapeHtml(item.ownerName || item.createdByName || 'Belgilanmagan')}</span>
              </div>
            </div>
            <span class="badge">${escapeHtml(item.status || 'Raw')}</span>
          </div>
          <p>${escapeHtml(item.description || 'G\'oya tavsifi kiritilmagan.')}</p>
        </a>
      `).join('') : '<div class="workspace-empty"><h3>G\'oya yo\'q</h3><p>Workspace ichida hali g\'oya yaratilmagan.</p></div>';

      document.querySelectorAll('[data-owner-save]').forEach((button) => {
        button.addEventListener('click', async () => {
          const ideaId = button.dataset.ownerSave;
          const ownerUserId = document.querySelector(`[data-owner-select="${ideaId}"]`)?.value;
          const feedback = document.querySelector(`[data-owner-feedback="${ideaId}"]`);
          if (feedback) {
            feedback.className = 'text-sm muted feedback-error';
            feedback.textContent = '';
          }
          button.disabled = true;
          try {
            await MllyCore.updateStartupOwner({ teamId: data.team.id, ideaId, ownerUserId });
            if (feedback) {
              feedback.className = 'text-sm muted feedback-success';
              feedback.textContent = "Mas'ul yangilandi.";
            }
            await refreshWorkspace(data.team.id, currentUserId);
          } catch (error) {
            if (feedback) feedback.textContent = error.message || "Mas'ul yangilanmadi.";
            button.disabled = false;
          }
        });
      });
    }

    function renderTasks(data, currentUserId, isLead, isViewer) {
      const tasks = data.tasks || [];
      const submissions = data.taskSubmissions || [];
      const memberCount = data.members.length || 1;
      const target = document.getElementById('tasksList');
      const count = document.getElementById('taskCount');
      if (count) count.textContent = tasks.length + ' ta';

      // Guruhlarni statuslar bo'yicha ajratamiz
      var groups = {
        open: tasks.filter(t => (t.status || 'open') === 'open'),
        in_progress: tasks.filter(t => t.status === 'in_progress'),
        done: tasks.filter(t => t.status === 'done' || t.status === 'completed'),
        submitted: tasks.filter(t => t.status === 'submitted')
      };

      var COLUMNS = [
        { key: 'open', label: '📋 Ochiq', status: 'open', emptyMsg: 'Ochiq topshiriq yo\'q' },
        { key: 'in_progress', label: '🔧 Bajarilmoqda', status: 'in_progress', emptyMsg: 'Bajarilayotgan topshiriq yo\'q' },
        { key: 'submitted', label: '🔍 Tekshiruvda', status: 'submitted', emptyMsg: 'Tekshiruvdagi topshiriq yo\'q' },
        { key: 'done', label: '✅ Tugallangan', status: 'done', emptyMsg: 'Tugallangan topshiriq yo\'q' }
      ];

      target.innerHTML = '<div class="kanban-board">' + COLUMNS.map(function(col) {
        var colTasks = groups[col.key] || [];
        return '<div class="kanban-column" data-status="' + col.status + '" data-column="' + col.key + '">' +
          '<div class="kanban-column-header"><span>' + col.label + '</span><span class="count">' + colTasks.length + '</span></div>' +
          (colTasks.length ? colTasks.map(function(task) {
            return renderTaskCard(task, data, submissions, memberCount, currentUserId, isLead, isViewer);
          }).join('') : '<div class="kanban-empty">' + col.emptyMsg + '</div>') +
        '</div>';
      }).join('') + '</div>';

      // Event listenerlarni qayta ulash
      setTimeout(() => attachTaskListeners(data, currentUserId, isLead, isViewer), 0);
      setTimeout(() => attachColumnDragDrop(data, currentUserId), 50);
    }

    function renderTaskCard(task, data, submissions, memberCount, currentUserId, isLead, isViewer) {
      var taskSubs = submissions.filter(item => item.taskId === task.id);
      var hasSubmitted = taskSubs.some(item => item.userId === currentUserId);
      var assignedId = task.assignedTo || task.assignedUserId || null;
      var assignedName = task.assignedUserName ||
        ((data.members || []).find(m => m.userId === assignedId)?.user?.name) ||
        ((data.members || []).find(m => m.userId === assignedId)?.name) || null;
      var mode = task.assignmentMode || (assignedId ? 'direct' : 'open');
      var isAssignedToCurrent = assignedId === currentUserId;
      var canClaim = !isViewer && mode === 'open' && !assignedId;
      var canSubmit = !isViewer && (
        (mode === 'team') ||
        ((mode === 'direct' || mode === 'open') && isAssignedToCurrent)
      ) && !hasSubmitted && task.status !== 'completed' && task.status !== 'done';
      var canComplete = (isLead || isAssignedToCurrent) && (task.status === 'in_progress' || task.status === 'submitted');
      var isSubmitted = task.status === 'submitted';

      return '<div class="kanban-task" draggable="true" data-task-id="' + task.id + '" data-status="' + (task.status || 'open') + '" onclick="openTaskDetail(\'' + task.id + '\')">' +
        '<div class="kanban-task-title">' + escapeHtml(task.title) + '</div>' +
        '<div class="kanban-task-meta">' +
          '<span class="badge">' + escapeHtml(mode) + '</span>' +
          '<span class="badge ' + (isSubmitted ? 'badge-active' : '') + '">' + escapeHtml(task.status || 'open') + '</span>' +
          (task.blocked ? '<span class="badge" style="background:#7f1d1d;color:#fff">🔒 Bloklangan</span>' : '') +
        '</div>' +
        '<div class="kanban-task-footer">' +
          '<span>' + escapeHtml(assignedName || (mode === 'team' ? 'Jamoaviy' : 'Hali olinmagan')) + '</span>' +
          '<span>' + (task.deadlineAt ? fmtDate(task.deadlineAt) : '') + '</span>' +
        '</div>' +
        (canClaim ? '<button class="btn btn-secondary btn-sm" data-task-claim="' + task.id + '" style="margin-top:6px">Topshiriqni olish</button>' : '') +
        (canSubmit ? '<button class="btn btn-primary btn-sm" data-task-submit="' + task.id + '" style="margin-top:6px">Tugatdim</button>' : '') +
        (canComplete ? '<button class="btn btn-primary btn-sm" data-task-complete="' + task.id + '" style="margin-top:6px">✅ Tugallash</button>' : '') +
      '</div>';
    }

    window.openTaskDetail = function(taskId) {
      var panel = document.getElementById('tskPanel');
      var body = document.getElementById('tskPanelBody');
      var bd = document.getElementById('tskBackdrop');
      if (!panel || !body) return;
      showTskDetail(taskId, panel, body);
      panel.classList.add('expanded');
      if (bd) bd.style.display = 'block';
    };

    function attachTaskListeners(data, currentUserId, isLead, isViewer) {
      document.querySelectorAll('[data-task-claim]').forEach(button => {
        button.addEventListener('click', async function(e) {
          e.stopPropagation();
          var taskId = button.dataset.taskClaim;
          button.disabled = true;
          try {
            await MllyCore.claimOpenTask(taskId);
            await refreshWorkspace(data.team.id, currentUserId);
          } catch (error) {
            UTIL.toast(error.message || 'Topshiriq olinmadi.');
            button.disabled = false;
          }
        });
      });

      document.querySelectorAll('[data-task-submit]').forEach(button => {
        button.addEventListener('click', async function(e) {
          e.stopPropagation();
          var taskId = button.dataset.taskSubmit;
          var resultText = prompt('Natijani yozing:', '');
          if (resultText === null) return;
          button.disabled = true;
          try {
            await MllyCore.submitTaskResult({ taskId: taskId, resultText: resultText || '', resultLink: '' });
            await refreshWorkspace(data.team.id, currentUserId);
          } catch (error) {
            UTIL.toast(error.message || 'Natija yuborilmadi.');
            button.disabled = false;
          }
        });
      });

      document.querySelectorAll('[data-task-complete]').forEach(button => {
        button.addEventListener('click', async function(e) {
          e.stopPropagation();
          var taskId = button.dataset.taskComplete;
          button.disabled = true;
          try {
            await MllyCore.setTaskStatus({ taskId: taskId, status: 'done' });
            await refreshWorkspace(data.team.id, currentUserId);
          } catch (error) {
            UTIL.toast(error.message || 'Topshiriq tugallanmadi.');
            button.disabled = false;
          }
        });
      });
    }

    function attachColumnDragDrop(data, currentUserId) {
      var tasks = document.querySelectorAll('.kanban-task[draggable="true"]');
      var columns = document.querySelectorAll('.kanban-column');

      tasks.forEach(function(task) {
        task.addEventListener('dragstart', function(e) {
          this.classList.add('dragging');
          e.dataTransfer.setData('text/plain', this.dataset.taskId);
          e.dataTransfer.effectAllowed = 'move';
        });
        task.addEventListener('dragend', function() {
          this.classList.remove('dragging');
          columns.forEach(function(col) { col.classList.remove('drag-over'); });
        });
      });

      columns.forEach(function(col) {
        col.addEventListener('dragover', function(e) {
          e.preventDefault();
          this.classList.add('drag-over');
        });
        col.addEventListener('dragleave', function() {
          this.classList.remove('drag-over');
        });
        col.addEventListener('drop', async function(e) {
          e.preventDefault();
          this.classList.remove('drag-over');
          var taskId = e.dataTransfer.getData('text/plain');
          var newStatus = this.dataset.status;
          var taskEl = document.querySelector('.kanban-task[data-task-id="' + taskId + '"]');
          if (!taskEl || !taskId || !newStatus) return;
          var oldStatus = taskEl.dataset.status;
          if (oldStatus === newStatus) return;

          // Optimistik yangilash
          taskEl.setAttribute('data-status', newStatus);
          taskEl.classList.add('dragging');

          try {
            await MllyCore.setTaskStatus({ taskId: taskId, status: newStatus });
            await refreshWorkspace(data.team.id, currentUserId);
          } catch (error) {
            taskEl.setAttribute('data-status', oldStatus);
            taskEl.classList.remove('dragging');
            UTIL.toast(error.message || 'Status yangilanmadi.');
          }
        });
      });
    }

    function renderTaskCard(task, data, submissions, memberCount, currentUserId, isLead, isViewer) {
      var taskSubs = submissions.filter(function(item) { return item.taskId === task.id; });
      var hasSubmitted = taskSubs.some(function(item) { return item.userId === currentUserId; });
      var assignedId = task.assignedTo || task.assignedUserId || null;
      var assignedName = task.assignedUserName ||
        ((data.members || []).find(function(m) { return m.userId === assignedId; })?.user?.name) ||
        ((data.members || []).find(function(m) { return m.userId === assignedId; })?.name) || null;
      var mode = task.assignmentMode || (assignedId ? 'direct' : 'open');
      var isAssignedToCurrent = assignedId === currentUserId;
      var canClaim = !isViewer && mode === 'open' && !assignedId;
      var canSubmit = !isViewer && (
        (mode === 'team') ||
        ((mode === 'direct' || mode === 'open') && isAssignedToCurrent)
      ) && !hasSubmitted && task.status !== 'completed' && task.status !== 'done';
      var canComplete = (isLead || isAssignedToCurrent) && (task.status === 'in_progress' || task.status === 'submitted');

      return '<div class="kanban-task" draggable="true" data-task-id="' + task.id + '" data-status="' + (task.status || 'open') + '">' +
        '<div class="kanban-task-title">' + escapeHtml(task.title) + '</div>' +
        '<div class="kanban-task-meta">' +
          '<span class="badge">' + escapeHtml(mode) + '</span>' +
          '<span class="badge">' + escapeHtml(task.status || 'open') + '</span>' +
          (task.blocked ? '<span class="badge" style="background:#7f1d1d;color:#fff">🔒 Bloklangan</span>' : '') +
        '</div>' +
        '<div class="kanban-task-footer">' +
          '<span>' + escapeHtml(assignedName || (mode === 'team' ? 'Jamoaviy' : 'Hali olinmagam')) + '</span>' +
          '<span>' + (task.deadlineAt ? fmtDate(task.deadlineAt) : '') + '</span>' +
        '</div>' +
        (canClaim ? '<button class="btn btn-secondary btn-sm" data-task-claim="' + task.id + '" style="margin-top:6px">Topshiriqni olish</button>' : '') +
        (canSubmit ? '<button class="btn btn-primary btn-sm" data-task-submit="' + task.id + '" style="margin-top:6px">Tugatdim</button>' : '') +
        (canComplete ? '<button class="btn btn-primary btn-sm" data-task-complete="' + task.id + '" style="margin-top:6px">✅ Tugallash</button>' : '') +
      '</div>';
    }

