        </section>

      <!-- Task slide-out panel (fixed overlay) -->
      <div class="tsk-panel-backdrop" id="tskBackdrop"></div>
      <div class="tsk-panel" id="tskPanel">
        <div class="tsk-panel-head">
          <h3 id="tskPanelTitle">📋 Topshiriqlar</h3>
          <div class="tsk-panel-head-actions">
            <button class="btn btn-tertiary btn-sm" id="tskPanelClose" title="Yopish">✕</button>
          </div>
        </div>
        <div class="tsk-panel-body" id="tskPanelBody"></div>
      </div>
      `;

      renderEntries(data, currentUserId, isLead, isManagerViewer);
      renderTasks(data, currentUserId, isLead, (membership?.role === 'viewer') || isManagerViewer);
      renderMembers(data, currentUserId, isLead, isManagerViewer);
      // T9 - Presence: har bir a'zo holatini realtime obuna qilish.
      // FIX (presenceUnsubs cleanup): avvalgi obunalarni to'liq tozalash
      _cleanupPresence();
      
      const PRESENCE_STALE_MS = 5 * 60 * 1000; // 5 daqiqa
      if (data.members) {
        data.members.forEach((member) => {
          MllyCore.subscribePresence(member.userId, (p) => {
            const dot = document.getElementById('presence-' + member.userId);
            if (!dot) return;
            // Statusni aniqlash
            let st = (p && p.status) || 'offline';
            // `updatedAt` bo'yicha stale check
            if (p) {
              const lastTs = p.updatedAt;
              if (typeof lastTs === 'number') {
                if (Date.now() - lastTs > PRESENCE_STALE_MS) {
                  st = 'offline';
                }
              } else if (lastTs && typeof lastTs.toMillis === 'function') {
                if (Date.now() - lastTs.toMillis() > PRESENCE_STALE_MS) {
                  st = 'offline';
                }
              }
            }
            dot.style.background = st === 'online' ? '#22c55e' : st === 'away' ? '#f59e0b' : '#64748b';
            dot.title = st;
          }).then((unsub) => { if (typeof unsub === 'function') presenceUnsubs.push(unsub); }).catch(() => {});
        });
      }
      // FIX: visibility change bo'lganda, agar tab visible bo'lsa, fresh presence subscribe qilish
      _presenceVisibilityHandler = function() {
        if (document.visibilityState === 'visible' && data.team && data.team.id) {
          refreshWorkspace(data.team.id, currentUserId);
        }
      };
      document.addEventListener('visibilitychange', _presenceVisibilityHandler);
      renderChat(data.messages || [], currentUserId);

      // FIX (accordion -> professional TAB pattern): Endi bo'limlar yuqorida
      // gorizontal tab bar sifatida ko'rinadi, birini bossangiz o'sha panel ochiladi,
      // qolganlari yopiladi. The ws-section-head elementlari avtomatik ws-tab ga aylanadi.
      (() => {
        const accordion = document.querySelector('.ws-accordion');
        if (!accordion) return;
        
        // Agar tab bar allaqachon mavjud bo'lsa, qayta yaratmaymiz
        if (accordion.querySelector('.ws-tab-bar')) return;
        
        const sections = Array.from(accordion.querySelectorAll('.ws-section'));
        if (!sections.length) return;
        const teamKey = 'mlly_sec_' + (data.team && data.team.id || '');
        
        // 1. Tab bar yaratish
        const tabBar = document.createElement('nav');
        tabBar.className = 'ws-tab-bar';
        tabBar.setAttribute('role', 'tablist');
        tabBar.setAttribute('aria-label', "Workspace bo'limlari");
        
        // 2. Har bir section head ni tab ga aylantirish
        const tabs = [];
        sections.forEach((sec) => {
          const head = sec.querySelector('.ws-section-head');
          if (!head) return;
          const tabId = sec.dataset.section || 'tab';
          
          // ws-section-head ni ws-tab ga aylantirish
          head.classList.remove('ws-section-head');
          head.classList.add('ws-tab');
          head.setAttribute('role', 'tab');
          head.setAttribute('aria-controls', 'tabpanel-' + tabId);
          head.dataset.tab = tabId;
          
          // ▾ ikonasini olib tashlash (tabs are not accordion)
          const ico = head.querySelector('.ws-section-ico');
          if (ico) ico.remove();
          
          tabBar.appendChild(head);
          tabs.push(head);
        });
        
        // 3. Section body larni tabpanel ga aylantirish
        const panels = [];
        sections.forEach((sec) => {
          const body = sec.querySelector('.ws-section-body');
          if (!body) return;
          const tabId = sec.dataset.section || 'panel';
          
          body.classList.remove('ws-section-body');
          body.classList.add('ws-tab-panel');
          body.setAttribute('role', 'tabpanel');
          body.dataset.tab = tabId;
          body.id = 'tabpanel-' + tabId;
          body.removeAttribute('hidden');
          
          panels.push(body);
        });
        
        // 4. Tab barni accordion boshiga qo'shish
        accordion.insertBefore(tabBar, accordion.firstChild);
        
        // 5. Section o'ramini olib tashlash (faqat panel qoladi)
        sections.forEach((sec) => {
          const body = sec.querySelector('.ws-tab-panel');
          if (body) {
            sec.parentNode.insertBefore(body, sec);
          }
          sec.remove();
        });
        
        // 6. Tab logikasi
        const setActive = (tab) => {
          const tabId = tab.dataset.tab || tab.getAttribute('aria-controls')?.replace('tabpanel-', '') || '';
          tabs.forEach((t) => {
            const isActive = t === tab;
            t.setAttribute('aria-selected', String(isActive));
            t.classList.toggle('active', isActive);
          });
          panels.forEach((p) => {
            const isActive = p.dataset.tab === tabId || p.id === 'tabpanel-' + tabId;
            p.hidden = !isActive;
            p.classList.toggle('active', isActive);
          });
          try { localStorage.setItem(teamKey, tabId); } catch (_) {}
        };
        
        tabs.forEach((tab) => {
          tab.addEventListener('click', () => setActive(tab));
        });
        
        // 7. Dastlabki holat
        let defaultTab = tabs.find((t) => t.dataset.tab === 'kanban');
        // localStorage dan tiklash
        try {
          const saved = localStorage.getItem(teamKey);
          if (saved) {
            const savedTab = tabs.find((t) => (t.dataset.tab === saved));
            if (savedTab) defaultTab = savedTab;
          }
        } catch (_) {}
        if (defaultTab) setActive(defaultTab);
        else if (tabs.length) setActive(tabs[0]);
      })();

      // Boshqaruv (sobiq "Faoliyat") ichki sub-nav: moliya / jamoa / integratsiya guruhlari.
      // Bosilganda activity panel-ning data-bq qiymatini o'zgartiramiz; CSS shu orqali
      // tegishli guruhdagi accordion-larni ko'rsatadi, qolganlarini yashiradi.
      (() => {
        const actPanel = document.getElementById('tabpanel-activity');
        if (!actPanel) return;
        const bqBtns = Array.from(actPanel.querySelectorAll('.ws-boshqaruv-nav .subnav-item'));
        if (!bqBtns.length) return;
        const setBq = (bq) => {
          actPanel.dataset.bq = bq;
          bqBtns.forEach((b) => b.setAttribute('aria-current', String(b.dataset.bq === bq)));
        };
        bqBtns.forEach((b) => b.addEventListener('click', () => setBq(b.dataset.bq)));
        // Klaviatura navigatsiyasi (ArrowLeft/Right) uchun qulaylik.
        const nav = actPanel.querySelector('.ws-boshqaruv-nav');
        nav?.addEventListener('keydown', (e) => {
          if (e.key !== 'ArrowRight' && e.key !== 'ArrowLeft') return;
          const i = bqBtns.indexOf(document.activeElement);
          if (i < 0) return;
          const next = e.key === 'ArrowRight' ? (i + 1) % bqBtns.length : (i - 1 + bqBtns.length) % bqBtns.length;
          bqBtns[next].focus();
          e.preventDefault();
        });
      })();

      // T21 / T23 / T24 / T28 / T30 / T36 — collapsible (ochiladigan) panel.
      // Har bir funksiya alohida bo'lim; ustidan bosganda ochiladi, ma'lumot faqat bir marta yuklanadi (tezlik uchun).
      (async () => {
        const teamIdT = data.team.id;
        const loadedAcc = {};

                // T46 — Webhook ro'yxatini yuklash, test / o'chirish (delete) amallari
        window.renderWebhooks = async (teamId, body) => {
          const status = document.getElementById('webhookStatus');
          const listEl = document.getElementById('webhookList');
          if (!listEl) return;
          try {
            const r = await MllyCore.getWebhookList(teamId);
            const hooks = r.webhooks || [];
            listEl.innerHTML = hooks.length ? hooks.map((h) => `
              <div class=\"workspace-message-item\" data-webhook-id=\"${h.id}\">
                <div>
                  <strong>${escapeHtml(h.url)}</strong>
                  <span>${(h.events || []).join(', ')}</span>
                </div>
                <div class=\"workspace-subgrid cols-2\" style=\"gap:6px;margin-top:6px\">
                  <button class=\"btn btn-secondary btn-sm\" data-webhook-test=\"${h.id}\">Test</button>
                  <button class=\"btn btn-danger btn-sm\" data-webhook-del=\"${h.id}\">O'chirish</button>
                </div>
              </div>`).join('') : '<div class=\"muted\">Hozircha webhook yo‘q</div>';

            listEl.querySelectorAll('[data-webhook-test]').forEach((btn) => {
              btn.addEventListener('click', async () => {
                btn.disabled = true;
                try {
                  const res = await MllyCore.testWebhook(btn.dataset.webhookTest);
                  if (status) status.textContent = (res && res.success) ? 'Test yuborildi (kod: ' + (res.statusCode || '?') + ')' : 'Test xatosi: ' + ((res && res.error) || 'noma’lum');
                } catch (e) { if (status) status.textContent = e.message; }
                finally { btn.disabled = false; }
              });
            });
            listEl.querySelectorAll('[data-webhook-del]').forEach((btn) => {
              btn.addEventListener('click', async () => {
                btn.disabled = true;
                try {
                  await MllyCore.deleteWebhook(btn.dataset.webhookDel);
                  await renderWebhooks(teamId, body);
                  if (status) status.textContent = 'Webhook o‘chirildi.';
                } catch (e) { if (status) status.textContent = e.message; btn.disabled = false; }
              });
            });
          } catch (e) { listEl.textContent = e.message; }
        };

        window.renderList = (container, title, arr, fmt) => {
          container.innerHTML = `<h3 style=\"margin:8px 0 4px;\">${title}</h3>` + (arr && arr.length ? `<div class=\"workspace-message-stack\">${arr.map(fmt).join('')}</div>` : '<div class=\"muted\">Ma’lumot yo’q</div>');
        };

        document.querySelectorAll('.ws-acc-head').forEach((head) => {
          head.addEventListener('click', async () => {
            const acc = head.closest('.ws-acc');
            const key = head.dataset.acc;
            const wasOpen = acc.classList.contains('open');
            document.querySelectorAll('.ws-acc').forEach((a) => a.classList.remove('open'));
            document.querySelectorAll('.ws-acc-head').forEach((h) => h.setAttribute('aria-expanded', 'false'));
            if (wasOpen) return;
            acc.classList.add('open');
            head.setAttribute('aria-expanded', 'true');

            if (loadedAcc[key]) return;
            const body = acc.querySelector('.ws-acc-body');
            try {
              if (key === 'roadmap' && body) {
                const r = await MllyCore.getRoadmap(teamIdT); loadedAcc.roadmap = true;
                renderList(body, '🗺 Roadmap', r.tasks, (t) => `<div class="workspace-message-item"><strong>${escapeHtml(t.title)}</strong> — ${escapeHtml(t.status || 'open')} ${Array.isArray(t.dependsOn) && t.dependsOn.length ? '🔒' : ''}</div>`);
              } else if (key === 'decisions' && body) {
                const list = await MllyCore.getDecisions(teamIdT); loadedAcc.decisions = true;
                renderList(body, '📌 Qarorlar', list, (d) => `<div class="workspace-message-item"><strong>${escapeHtml(d.title)}</strong><span>${escapeHtml(d.decision || '')}</span></div>`);
              } else if (key === 'reputation' && body) {
                const r = await MllyCore.getReputation(teamIdT); loadedAcc.reputation = true;
                renderList(body, '🏅 Reputation', r.members, (m) => `<div class="workspace-message-item"><strong>${escapeHtml(m.name)}</strong> — ${m.reputation || 0} ball (${escapeHtml(m.role)})</div>`);
              } else if (key === 'activity' && body) {
                const r = await MllyCore.getActivityFeed(teamIdT); loadedAcc.activity = true;
                renderList(body, '📡 Activity', r.feed, (f) => `<div class="workspace-message-item"><span>${escapeHtml(f.kind || '')}</span> <span>${escapeHtml(f.action || f.type || f.text || '')}</span></div>`);
              } else if (key === 'backup' && body) {
                loadedAcc.backup = true;
                body.innerHTML = '<div class="muted">Yuqoridagi tugmalardan foydalaning.</div>';
              } else if (key === 'load' && body) {
                loadedAcc.load = true;
                const r = await MllyCore.getTeamLoad(teamIdT);
                const s = r.summary || {};
                document.getElementById('loadSummary').textContent = 'Jamoa: ' + (s.members || 0) + ' a’zo — ' + (s.overloaded || 0) + ' overloaded, ' + (s.busy || 0) + ' busy';
                const colorOf = (sig) => sig === 'overloaded' ? '#e5484d' : sig === 'busy' ? '#f59e0b' : '#22c55e';
                body.innerHTML = '<div class="workspace-message-stack">' + (r.load || []).map((m) => '<div class="workspace-message-item"><strong>' + escapeHtml(nameOf(m, data.members)) + '</strong> — ' + m.openTasks + ' ochiq, ' + (m.timeLoggedMs / 3600000).toFixed(1) + ' soat, ' + m.presence + ' <span style="color:' + colorOf(m.signal) + '">' + m.signal + '</span></div>').join('') + '</div>';
              } else if (key === 'webhooks' && body) {
                loadedAcc.webhooks = true;
                await renderWebhooks(teamIdT, body);
              } else if (key === 'analytics' && body) {
                loadedAcc.analytics = true;
                const r = await MllyCore.getIdeaAnalytics(teamIdT);
                const sd = r.stageDistribution || {};
                const stagesStr = Object.entries(sd).map((e) => e[0] + ': ' + e[1]).join(', ');
                const sum = document.getElementById('analyticsSummary');
                if (sum) sum.innerHTML = 'Jami: ' + r.total + ' | O‘rtacha RICE: ' + r.avgRice + ' | Ovozlar: ' + r.totalVotes + ' | Eski (stale): ' + r.staleCount + '<br>Stage: ' + (stagesStr || '-');
                const top = document.getElementById('analyticsTop');
                if (top) top.innerHTML =
                  '<div class="workspace-message-item"><strong>Top RICE:</strong> ' + (r.topByScore || []).map((x) => escapeHtml(x.title) + ' (' + x.rice + ')').join(', ') + '</div>' +
                  '<div class="workspace-message-item"><strong>Top ovoz:</strong> ' + (r.topByVotes || []).map((x) => escapeHtml(x.title) + ' (' + x.votes + ')').join(', ') + '</div>';
                const list = document.getElementById('analyticsList');
                  if (list) list.innerHTML = '<div class="workspace-message-stack">' + (r.ideas || []).map((i) => '<div class="workspace-message-item"><strong>' + escapeHtml(i.title) + '</strong> — RICE ' + i.rice + ', stage ' + escapeHtml(i.stage || '-') + ', ovoz ' + i.voteCount + (i.stale ? ' ⚠ stale' : '') + '</div>').join('') + '</div>';
              } else if (key === 'attachments' && body) {
                loadedAcc.attachments = true;
                const rA = await MllyCore.listAttachments({ teamId: teamIdT });
                const listA = document.getElementById('attachmentsList');
                const statusA = document.getElementById('attachmentsStatus');
                if (statusA) statusA.textContent = (rA.attachments || []).length + ' ta fayl';
                if (listA) listA.innerHTML = (rA.attachments || []).length ? (rA.attachments || []).map((a) => {
                  const vers = (a.versions || []);
                  const verHtml = vers.length ? '<div class="ws-sub" style="margin-top:6px;font-size:12px;color:var(--text-muted);">Tarix: ' + vers.slice().reverse().map((v) => 'v' + v.version + ' (' + escapeHtml(v.uploadedByName) + ')').join(', ') + '</div>' : '';
                  return '<div class="workspace-message-item"><strong>' + escapeHtml(a.fileName) + '</strong> <span>v' + (a.version || 1) + ' · ' + escapeHtml(a.uploadedByName) + (a.size ? ' · ' + (a.size / 1024).toFixed(1) + ' KB' : '') + '</span>' + verHtml + '</div>';
                }).join('') : '<div class="muted">Hozircha biriktirma yo‘q</div>';
              } else if (key === 'timezone' && body) {
                loadedAcc.timezone = true;
                const TZS = ['UTC', 'Asia/Tashkent', 'Asia/Almaty', 'Europe/Istanbul', 'Europe/Moscow', 'Europe/Berlin', 'Europe/London', 'America/New_York', 'America/Los_Angeles', 'Asia/Dubai', 'Asia/Kolkata', 'Australia/Sydney'];
                const optHtml = (sel) => TZS.map((z) => '<option value="' + z + '"' + (z === sel ? ' selected' : '') + '>' + z + '</option>').join('');
                const myTz = await MllyCore.getTimezone().catch(() => ({ timezone: 'UTC' }));
                const cur = myTz.timezone || 'UTC';
                ['tzMySelect', 'tzFromTz', 'tzToTz', 'tzScheduleTz'].forEach((id) => {
                  const el = document.getElementById(id);
                  if (el) el.innerHTML = optHtml(cur);
                });
                const nowLocal = new Date(Date.now() - new Date().getTimezoneOffset() * 60000).toISOString().slice(0, 16);
                const fromEl = document.getElementById('tzFromInput');
                const schedEl = document.getElementById('tzScheduleWhen');
                if (fromEl && !fromEl.value) fromEl.value = nowLocal;
                if (schedEl && !schedEl.value) schedEl.value = nowLocal;
                const sList = document.getElementById('tzScheduleList');
                try {
                  const sR = await MllyCore.listSchedules({ teamId: teamIdT });
                  if (sList) sList.innerHTML = (sR.schedules || []).length ? (sR.schedules || []).map((s) => '<div class="workspace-message-item"><strong>' + escapeHtml(s.title) + '</strong> <span>' + escapeHtml(s.iso) + ' (' + escapeHtml(s.timezone) + ')</span></div>').join('') : '<div class="muted">Rejalashtirilgan eslatma yo‘q</div>';
                } catch (_) { if (sList) sList.textContent = ''; }
              }
            } catch (e) {
              if (body) body.textContent = e.message;
            }
          });
        });

        // T30 Meeting saqlash
        document.getElementById('meetingSaveBtn')?.addEventListener('click', async () => {
          try {
            await MllyCore.saveMeetingNotes({
              teamId: teamIdT,
              title: document.getElementById('meetingTitle').value,
              notes: document.getElementById('meetingNotes').value,
              actionItems: document.getElementById('meetingActions').value.split(',').map((s) => s.trim()).filter(Boolean)
            });
            UTIL.toast('Meeting saqlandi');
          } catch (e) { UTIL.toast(e.message); }
        });

        // T23 Moliyaviy — inline forma (prompt'siz), runway darhol ko'rsatiladi
        document.getElementById('financeSaveBtn')?.addEventListener('click', async () => {
          const fb = document.getElementById('financeRunway');
          const btn = document.getElementById('financeSaveBtn');
          btn.disabled = true;
          try {
            await MllyCore.saveFinances({
              teamId: teamIdT,
              monthlyBudget: Number(document.getElementById('financeBudget').value) || 0,
              burnRate: Number(document.getElementById('financeBurn').value) || 0,
              currency: document.getElementById('financeCurrency').value || 'USD'
            });
            const r = await MllyCore.getRunway(teamIdT);
            fb.innerHTML = `<div class="workspace-message-item"><strong>Qolgan oy:</strong> ${r.runwayMonths === null ? '∞ (burn=0)' : r.runwayMonths + ' oy'}</div>`;
            UTIL.toast('Moliyaviy saqlandi');
          } catch (e) { if (fb) fb.textContent = e.message; }
          finally { btn.disabled = false; }
        });

        // T41 Backup — Export / Import
        document.getElementById('exportBackupBtn')?.addEventListener('click', async () => {
          try {
            const ws = await MllyCore.exportWorkspace(teamIdT);
            const blob = new Blob([JSON.stringify(ws, null, 2)], { type: 'application/json' });
            const url = URL.createObjectURL(blob);
            const a = document.createElement('a');
            a.href = url; a.download = 'mllycore-backup-' + teamIdT + '.json'; a.click();
            URL.revokeObjectURL(url);
            document.getElementById('backupStatus').textContent = 'Export tayyor.';
          } catch (e) { document.getElementById('backupStatus').textContent = e.message; }
        });
        document.getElementById('importBackupBtn')?.addEventListener('click', () => document.getElementById('importBackupFile')?.click());
        document.getElementById('importBackupFile')?.addEventListener('change', async (e) => {
          const file = e.target.files[0];
          if (!file) return;
          try {
            const parsed = JSON.parse(await file.text());
            const res = await MllyCore.importWorkspace(teamIdT, parsed);
            document.getElementById('backupStatus').textContent = 'Import qilindi: ' + (res.imported || 0) + ' yozuv.';
          } catch (err) { document.getElementById('backupStatus').textContent = err.message; }
        });

        // T46 Webhooks — qo'shish (add)
        document.getElementById('webhookAddBtn')?.addEventListener('click', async () => {
          const urlInput = document.getElementById('webhookUrl');
          const status = document.getElementById('webhookStatus');
          const events = Array.from(document.querySelectorAll('.webhook-event:checked')).map((c) => c.value);
          const url = (urlInput?.value || '').trim();
          if (!url) { if (status) status.textContent = 'URL kiriting.'; return; }
          const btn = document.getElementById('webhookAddBtn');
          if (btn) btn.disabled = true;
          try {
            await MllyCore.addWebhook({ teamId: teamIdT, url, events: events.length ? events : ['*'] });
            if (urlInput) urlInput.value = '';
            if (status) status.textContent = 'Webhook qo‘shildi.';
            await renderWebhooks(teamIdT, document.getElementById('acc-webhooks'));
          } catch (e) { if (status) status.textContent = e.message; }
          finally { if (btn) btn.disabled = false; }
        });

        // T55 — Timezone preferences (shaxsiy timezone saqlash)
        document.getElementById('tzSaveBtn')?.addEventListener('click', async () => {
          const sel = document.getElementById('tzMySelect');
          const status = document.getElementById('tzSaveStatus');
          try {
            await MllyCore.saveTimezone({ timezone: sel?.value, teamId: teamIdT });
            if (status) status.textContent = 'Timezone saqlandi: ' + (sel?.value || '');
          } catch (e) { if (status) status.textContent = e.message; }
        });

        // T55 — Time converter + working-hours check
        document.getElementById('tzConvertBtn')?.addEventListener('click', async () => {
          const iso = document.getElementById('tzFromInput')?.value;
          const fromTz = document.getElementById('tzFromTz')?.value || 'UTC';
          const toTz = document.getElementById('tzToTz')?.value || 'UTC';
          const resEl = document.getElementById('tzConvertResult');
          const whEl = document.getElementById('tzWhResult');
          if (!iso) { if (resEl) resEl.textContent = 'Vaqt kiriting.'; return; }
          try {
            const r = await MllyCore.convertTime({ iso, fromTz, toTz });
            if (resEl) resEl.textContent = iso + ' (' + fromTz + ') = ' + r.to.local + ' (' + toTz + ')';
            const wh = await MllyCore.checkWorkingHours({ iso, tz: fromTz });
            if (whEl) whEl.textContent = 'Ish vaqti (' + fromTz + '): ' + wh.localTime + ' — ' + (wh.within ? '✅ ichida' : '🌙 tashqarisida');
          } catch (e) { if (resEl) resEl.textContent = e.message; }
        });

        // T55 — Schedule a team reminder (rejalashtirilgan eslatma)
        document.getElementById('tzScheduleBtn')?.addEventListener('click', async () => {
          const title = document.getElementById('tzScheduleTitle')?.value;
          const iso = document.getElementById('tzScheduleWhen')?.value;
          const tz = document.getElementById('tzScheduleTz')?.value || 'UTC';
          const status = document.getElementById('tzScheduleStatus');
          if (!title || !iso) { if (status) status.textContent = 'Nomi va vaqtni kiriting.'; return; }
          try {
            await MllyCore.createSchedule({ teamId: teamIdT, title, iso, tz });
            if (status) status.textContent = 'Rejalashtirildi: ' + title;
            const sR = await MllyCore.listSchedules({ teamId: teamIdT });
            const sList = document.getElementById('tzScheduleList');
            if (sList) sList.innerHTML = (sR.schedules || []).map((s) => '<div class="workspace-message-item"><strong>' + escapeHtml(s.title) + '</strong> <span>' + escapeHtml(s.iso) + ' (' + escapeHtml(s.timezone) + ')</span></div>').join('');
          } catch (e) { if (status) status.textContent = e.message; }
        });

        // T48 — Live Collaboration: real-time kursolar va presence
        if (window.__mllyCollabCleanup) { try { window.__mllyCollabCleanup(); } catch (_) {} window.__mllyCollabCleanup = null; }
        const cursorLayer = document.createElement('div');
        cursorLayer.id = 'cursorLayer';
        cursorLayer.className = 'cursor-layer';
        document.body.appendChild(cursorLayer);
        const collabBar = document.createElement('div');
        collabBar.id = 'collabPresence';
        collabBar.className = 'collab-presence';
        document.querySelector('.workspace-command-tools')?.appendChild(collabBar);
        const myColor = '#' + Math.floor(Math.random() * 16777215).toString(16).padStart(6, '0');
        const myName = (window.MLLYCORE_PROFILE && (window.MLLYCORE_PROFILE.name || window.MLLYCORE_PROFILE.email)) || 'User';

        // FIX (complaint 10): jonli kursolar (kursorni kuzatib yuguradigan nuqtalar) ba'zan
        // bezovta qiladi. Shuning uchun ularni foydalanuvchi o'zi yoqishi/o'chirishi mumkin
        // (holat localStorage da saqlanadi). Presence (kim onlayn) esa doim ko'rinadi.
        const _cursorKey = 'mlly_cursor_enabled';
        let _cursorsOn = (() => { const v = localStorage.getItem(_cursorKey); return v === null ? true : v === '1'; })();
        let _unsubCursors = null;
        const _renderCursors = (cursors) => {
          if (!_cursorsOn) return;
          try {
            cursorLayer.innerHTML = '';
            const now = Date.now();
            const CURSOR_STALE_MS = 5 * 60 * 1000; // 5 daqiqa
            cursors.forEach((c) => {
              if (c.userId === window.MLLYCORE_AUTH_USER?.uid) return;
              // FIX: Kursorni faqat oxirgi 5 daqiqa ichida yangilangan bo'lsa ko'rsat
              const cursorTime = c.updatedAt;
              if (cursorTime) {
                const cursorMs = (typeof cursorTime.toMillis === 'function') ? cursorTime.toMillis() :
                               (typeof cursorTime === 'number') ? cursorTime :
                               (typeof cursorTime.seconds === 'number') ? cursorTime.seconds * 1000 : 0;
                if (cursorMs > 0 && now - cursorMs > CURSOR_STALE_MS) return; // eski kursor → o'tkazib yubor
              }
              const dot = document.createElement('div');
              dot.className = 'cursor-dot';
              dot.style.left = (c.x || 0) + 'px';
              dot.style.top = (c.y || 0) + 'px';
              dot.style.background = c.color || '#7dd3fc';
              dot.innerHTML = '<span class="cursor-label">' + escapeHtml(c.name || 'User') + '</span>';
              cursorLayer.appendChild(dot);
            });
          } catch (_) {}
        };
        const _move = (e) => {
          if (!_cursorsOn) return;
          const now = Date.now();
          if (now - (_move._last || 0) < 60) return;
          _move._last = now;
          MllyCore.updateCursor({ teamId: teamIdT, x: e.clientX, y: e.clientY, name: myName, color: myColor });
        };
        const _enableCursors = async () => {
          if (_unsubCursors) return;
          window.addEventListener('mousemove', _move);
          const unsub = await MllyCore.subscribeCursors(teamIdT, _renderCursors).catch(() => null);
          if (typeof unsub === 'function') _unsubCursors = unsub;
          cursorLayer.style.display = '';
        };
        const _disableCursors = () => {
          try { window.removeEventListener('mousemove', _move); } catch (_) {}
          if (typeof _unsubCursors === 'function') { _unsubCursors(); _unsubCursors = null; }
          cursorLayer.innerHTML = '';
          cursorLayer.style.display = 'none';
        };
        if (_cursorsOn) _enableCursors();

        const _cursorToggle = document.createElement('button');
        _cursorToggle.type = 'button';
        _cursorToggle.className = 'btn btn-tertiary btn-sm collab-toggle';
        _cursorToggle.textContent = _cursorsOn ? '👁 Kursolar: Yoq' : '👁 Kursolar: O‘ch';
        _cursorToggle.setAttribute('aria-pressed', String(_cursorsOn));
        _cursorToggle.title = 'Jonli kursolarni yoqish/o‘chirish';
        _cursorToggle.addEventListener('click', () => {
          _cursorsOn = !_cursorsOn;
          localStorage.setItem(_cursorKey, _cursorsOn ? '1' : '0');
          _cursorToggle.textContent = _cursorsOn ? '👁 Kursolar: Yoq' : '👁 Kursolar: O‘ch';
          _cursorToggle.setAttribute('aria-pressed', String(_cursorsOn));
          if (_cursorsOn) _enableCursors(); else _disableCursors();
        });
        collabBar.appendChild(_cursorToggle);

        window.__mllyCollabCleanup = () => {
          try { window.removeEventListener('mousemove', _move); } catch (_) {}
          try { if (cursorLayer.parentNode) cursorLayer.parentNode.removeChild(cursorLayer); } catch (_) {}
          try { if (collabBar.parentNode) collabBar.parentNode.removeChild(collabBar); } catch (_) {}
          try { if (_unsubCursors) _unsubCursors(); } catch (_) {}
        };

        // T53 — Automated Weekly Report (Telegram + in-app)
        document.getElementById('weeklyReportBtn')?.addEventListener('click', async () => {
          const status = document.getElementById('weeklyReportStatus');
          const btn = document.getElementById('weeklyReportBtn');
          if (status) status.textContent = 'Yuborilmoqda...';
          if (btn) btn.disabled = true;
          try {
            const r = await MllyCore.sendWeeklyReport({ teamId: teamIdT });
            if (status) status.textContent = 'Yuborildi: ' + (r.sentTelegram || 0) + ' ta Telegram, xulosa: ' + JSON.stringify(r.summary);
          } catch (e) { if (status) status.textContent = e.message; }
          finally { if (btn) btn.disabled = false; }
        });
      })();
      scheduleChatSeen(data.messages || [], currentUserId, data.team.id);

      if (focusType === 'tasks') {
        const taskCard = focusEntityId ? document.querySelector(`[data-task-id="${focusEntityId}"]`) : null;
        (taskCard || document.getElementById('tasksList'))?.scrollIntoView({ behavior: 'smooth', block: 'start' });
        taskCard?.classList.add('workspace-flash');
        setTimeout(() => taskCard?.classList.remove('workspace-flash'), 1800);
      } else if (focusType === 'ideas' || focusType === 'startup') {
        const selector = focusType === 'startup' ? `[data-startup-id="${focusEntityId}"]` : `[data-idea-id="${focusEntityId}"]`;
        const card = focusEntityId ? document.querySelector(selector) : null;
        (card || document.getElementById(focusType === 'startup' ? 'startupList' : 'ideasList'))?.scrollIntoView({ behavior: 'smooth', block: 'start' });
        card?.classList.add('workspace-flash');
        setTimeout(() => card?.classList.remove('workspace-flash'), 1800);
      } else if (focusType === 'chat') {
        document.getElementById('chatMessages')?.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }

      if (chatSubscribedTeamId !== data.team.id) {
        if (chatUnsubscribe) chatUnsubscribe();
        chatSubscribedTeamId = data.team.id;
        chatUnsubscribe = await MllyCore.subscribeTeamChat(data.team.id, async (messages) => {
          if (workspaceState) {
            workspaceState = { ...workspaceState, messages };
          }
          renderChat(messages, currentUserId);
          scheduleChatSeen(messages, currentUserId, data.team.id);
        });
      }
      markWorkspaceNotificationsSeen(data);

      document.getElementById('sendChatBtn')?.addEventListener('click', async () => {
        const input = document.getElementById('chatText');
        const button = document.getElementById('sendChatBtn');
        button.disabled = true;
        try {
          await MllyCore.sendChatMessage({ teamId: data.team.id, text: input.value });
          input.value = '';
        } catch (error) {
          UTIL.toast(error.message || 'Xabar yuborilmadi');
        } finally {
          button.disabled = false;
          input.focus();
        }
      });

      document.getElementById('chatText')?.addEventListener('keydown', (event) => {
        if (event.key === 'Enter' && !event.shiftKey) {
          event.preventDefault();
          document.getElementById('sendChatBtn')?.click();
        }
      });

      document.getElementById('createIdeaBtn')?.addEventListener('click', async () => {
