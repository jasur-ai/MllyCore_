      MllyCore.updatePresence('online').catch(() => {});
      // ===== Topshiriqlar slide-out panel (professional drawer) =====
      (function initTaskPanel() {
  // Use event delegation on document so listeners survive DOM re-renders
  document.addEventListener('click', function tskHandler(e) {
    const toggle = e.target.closest('#taskPanelToggle');
