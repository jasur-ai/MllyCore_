    if (toggle && panel) {
      const isOpen = panel.classList.contains('open');
      if (isOpen) { closeTskPanel(panel, body, bd); }
      else { openTskPanel(panel, body, bd); }
      return;
    }
    if ((closeBtn || (backdrop && e.target === backdrop)) && panel) {
      closeTskPanel(panel, body, bd);
      return;
    }
    if (closeBtn || backdrop) return;
    
    if (tskItem && panel) {
      const taskId = tskItem.dataset.taskId;
      if (taskId) showTskDetail(taskId, panel, body);
      return;
    }
    if (backBtn && panel && body) {
