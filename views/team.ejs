          await renderWorkspace(workspaceState, currentUserId);
      const lastTimeEl = document.getElementById('lastUpdateTime');
      if (lastTimeEl) lastTimeEl.textContent = "So'nggi yangilanish: " + new Date().toLocaleTimeString('uz-UZ', { hour: '2-digit', minute: '2-digit' });
