                  <div class="chat-messages" id="chatMessages"></div>
                  ${isManagerViewer ? `
                  <div class="chat-input chat-readonly">
                    <span class="muted" style="padding:8px 12px;display:block;font-size:13px">💡 Siz kuzatuvchi sifatida chatni o'qishingiz mumkin, lekin yozish uchun a'zo bo'lishingiz kerak.</span>
