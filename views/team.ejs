    });

    window.addEventListener('focus', () => {
      if (workspaceState?.messages?.length && workspaceState?.team?.id && window.MLLYCORE_AUTH_USER?.uid) {
        scheduleChatSeen(workspaceState.messages, window.MLLYCORE_AUTH_USER.uid, workspaceState.team.id);
      }
    });
    document.addEventListener('visibilitychange', () => {
      if (document.visibilityState === 'visible' && workspaceState?.messages?.length && workspaceState?.team?.id && window.MLLYCORE_AUTH_USER?.uid) {
        scheduleChatSeen(workspaceState.messages, window.MLLYCORE_AUTH_USER.uid, workspaceState.team.id);
      }
    });
  </script>
  <script>
    if ("serviceWorker" in navigator && location.protocol !== "file:") {
      var isLocalDevSW = location.hostname === "localhost" || location.hostname === "127.0.0.1";
      var registerSW = function() {
        navigator.serviceWorker.register("sw.js").catch(function(err) {
          console.warn("SW registration failed:", err);
        });
      };
      if (navigator.serviceWorker.controller) {
        navigator.serviceWorker.getRegistrations().then(function(regs) {
          if (isLocalDevSW) {
            regs.forEach(function(r) { try { r.unregister(); } catch(_) {} });
          } else {
            registerSW();
          }
        });
      } else {
        if (!isLocalDevSW) registerSW();
      }
    }
  </script>
