      const [dashboard, initialWorkspace] = await Promise.race([
        Promise.all([
          MllyCore.getDashboardData(user.uid, { forceFresh: true }).catch(err => {
            console.error('Dash load error:', err);
            return cachedDash;
          }),
          teamId ? MllyCore.getTeamData(teamId, { forceFresh: true }).catch(err => {
            console.error('Workspace load error:', err);
            return { _error: true, message: err.message };
          }) : Promise.resolve(null)
        ]),
        new Promise(function(resolve) {
          setTimeout(function() {
            resolve([cachedDash, { _timeout: true }]);
          }, 15000);
        })
      ]).catch(err => {
        console.error('Global race error:', err);
        return [cachedDash, { _error: true, message: err.message }];
      });
