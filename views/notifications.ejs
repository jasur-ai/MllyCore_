<!DOCTYPE html>
<html lang="uz" class="auth-required">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Bildirishnomalar - MllyCore</title>
  <!-- Xavfsizlik: JS yuklanmasa ham 20 soniyadan keyin avtomatik qayta yuklash -->
  <meta http-equiv="refresh" content="20;url=notifications.html?retry=1" id="metaHardTimeout">
  <link rel="icon" type="image/svg+xml" href="images/favicon.svg">
  <link rel="apple-touch-icon" href="images/favicon.svg">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <link rel="manifest" href="manifest.webmanifest">
  <meta name="theme-color" content="#0f172a">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="css/styles.css">
  <script src="js/icons.js"></script>
  <script>(function(){try{var s=localStorage.getItem('mllycore-theme')||'dark';document.documentElement.className=s==='light'?'theme-light':'theme-dark'}catch(_){document.documentElement.className='theme-dark';}})();</script>
</head>
<body>
  <a href="#app" class="skip-link">Asosiy kontentga o'tish</a>
  <div id="app">
    <div class="workspace-app">
      <section class="workspace-command">
        <div>
          <h1 class="workspace-command-title">Notification center</h1>
          <p class="workspace-command-copy">Takliflar, chat signal'lari va team activity shu yerda to'planadi.</p>
        </div>
      </section>

      <section class="workspace-layout">
        <div class="workspace-main-stack">
          <div class="workspace-surface">
            <div class="workspace-surface-head">
              <div>
                <h2>Team takliflari</h2>
                <div class="workspace-surface-copy">Secret key to'g'ri kiritilgandan keyin workspace ochiladi.</div>
              </div>
              <span class="badge" id="inviteCount">0</span>
            </div>
            <div class="workspace-card-grid" id="invites"></div>
          </div>

          <div class="workspace-surface">
            <div class="workspace-surface-head">
              <div>
                <h2>Bildirishnomalar</h2>
                <div class="workspace-surface-copy">Bosilganda kerakli joyga olib boradi va o'qilgan bo'ladi.</div>
              </div>
              <div class="workspace-stack-tight" style="align-items:end">
                <span class="badge" id="notificationCount">0</span>
                <button class="btn btn-secondary btn-sm" id="batchToggleBtn" type="button">📦 Guruhlangan</button>
              </div>
            </div>
            <div class="workspace-card-grid" id="list"></div>
            <div id="batchView" style="margin-top:12px;display:none;"></div>
          </div>
        </div>

        <aside class="workspace-side-stack">
          <div class="workspace-surface pad">
            <h3 style="margin:0 0 12px">Read status</h3>
            <p class="muted text-sm" style="margin:0">1 ta belgi - hali o'qilmagan. 2 ta belgi - o'qilgan. Idea, task yoki chat ichidan ko'rilsa ham avtomatik read bo'ladi.</p>
          </div>
        </aside>
      </section>
    </div>
  </div>
  <script src="js/theme.js"></script>
  <script src="js/firebase-config.js"></script>
  <script src="js/firebase-service.js"></script>
  <script src="js/auth-guard.js"></script>
  <script src="js/layout.js"></script>
  <script>
    // JavaScript ishlayapti — meta refreshni to'xtatamiz
    (function() {
      var meta = document.getElementById('metaHardTimeout');
      if (meta) { meta.content = ''; if (meta.parentNode) meta.parentNode.removeChild(meta); }
    })();
    // retry=1 bilan qayta yuklanganda — to'g'ridan-to'g'ri xato ko'rsatamiz
    if (location.search.indexOf('retry=1') !== -1) {
      document.getElementById('app').innerHTML = '<div class="workspace-app" style="display:flex;flex-direction:column;align-items:center;justify-content:center;min-height:60vh"><div class="workspace-empty"><h3>Yuklashda vaqt o\'tdi</h3><p>Sahifa avtomatik qayta yuklandi, ammo ma\'lumotlarni yuklashda davomiy muammo bor. Internet aloqangizni tekshiring.</p><button class="btn btn-primary" onclick="location.href=\'notifications.html\'">🔄 Qayta urinish</button></div></div>';
    }

    // Xavfsizlik: 15 soniya ichida ma'lumotlar yuklanmasa, xato xabarini ko'rsatamiz
    window.__mllyLoadingTimeout = setTimeout(() => {
      var container = document.getElementById('invites');
      if (!container || container.children.length > 0) return;
      document.getElementById('list').innerHTML = '<div class="workspace-empty"><h3>Yuklashda xatolik</h3><p>Ma\'lumotlarni yuklash uzoq vaqt oldi. Internet aloqangizni tekshiring yoki qayta urinib ko\'ring.</p><button class="btn btn-primary btn-sm" onclick="location.reload()">🔄 Qayta urinish</button></div>';
    }, 15000);
    window.__clearLoadingTimeout = () => {
      if (window.__mllyLoadingTimeout) {
        clearTimeout(window.__mllyLoadingTimeout);
        window.__mllyLoadingTimeout = null;
      }
    };

    const escapeHtml = (value) => String(value || '').replace(/[&<>"']/g, (char) => ({
      '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#039;'
    }[char]));
    const fmtDate = (value) => {
      if (!value) return '-';
      const date = value.toDate ? value.toDate() : new Date(value);
      return Number.isNaN(date.getTime()) ? '-' : date.toLocaleString('uz-UZ');
    };

    function notificationTarget(notification) {
      const type = String(notification.type || '');
      if (type === 'team_invite') return null;
      if (type === 'team_message') {
        return `team.html?id=${notification.teamId}&focus=chat&entity=${notification.relatedEntityId || notification.teamId}`;
      }
      if (type.startsWith('task_')) {
        return `team.html?id=${notification.teamId}&focus=tasks&entity=${notification.relatedEntityId || ''}`;
      }
      if (type.includes('idea') || type.includes('startup')) {
        return `idea.html?id=${notification.relatedEntityId}`;
      }
      if (type === 'team_joined' || type === 'team_invite_accepted') {
        return `team.html?id=${notification.teamId}`;
      }
      return notification.teamId ? `team.html?id=${notification.teamId}` : null;
    }

    function notificationChecks(notification) {
      const read = !(notification.unread || notification.isRead === false);
      return read ? '\u2713\u2713' : '\u2713';
    }

    function renderNotificationPage(data) {
      const invites = data.pendingInvites || [];
      document.getElementById('inviteCount').textContent = invites.length;
      // FIX (complaint 6): "Team takliflari" bo'limi faqat haqiqatan ham kutilayotgan
      // takliflar bo'lganda ko'rsatiladi. Aks holda (masalan, managerlar uchun bo'sh holatda)
      // keraksiz bo'lim chiqmaydi.
      // FIX (viewer logic): Admin va manager hech qachon taklif qabul qilmaydi —
      // shuning uchun ular uchun "Taklif" bo'limi butunlay yashiriladi.
      const profile = window.MLLYCORE_PROFILE || {};
      const isAdminManager = profile.role === 'admin' || profile.role === 'manager';
      const _invSec = document.getElementById('invites')?.closest('.workspace-surface');
      if (_invSec) _invSec.style.display = (invites.length && !isAdminManager) ? '' : 'none';
      const unreadN = (data.notifications || []).filter((n) => n.unread || n.isRead === false).length;
      const notifBadge = document.getElementById('notificationCount');
      notifBadge.textContent = unreadN;
      notifBadge.style.display = unreadN > 0 ? '' : 'none';

      document.getElementById('invites').innerHTML = invites.length ? invites.map((invite) => `
        <div class="workspace-record">
          <div class="workspace-record-top">
            <div>
              <h3>${escapeHtml(invite.teamName || 'Workspace')}</h3>
              <div class="workspace-inline-meta">
                <span>Taklif keldi</span>
                <span>${fmtDate(invite.createdAt)}</span>
              </div>
            </div>
            <span class="badge badge-progress">Pending</span>
          </div>
          <div class="workspace-form-stack mt-3">
            <div>
              <label class="label">Secret key</label>
              <input class="input" data-secret-key="${invite.id}" placeholder="XXXX-XXXX-XXXX-XXXX">
            </div>
            <div class="workspace-form-actions">
              <button class="btn btn-primary" data-accept-invite="${invite.id}">Qo'shilish</button>
            </div>
            <div class="text-sm muted" data-invite-error="${invite.id}"></div>
          </div>
        </div>
      `).join('') : '<div class="workspace-empty"><h3>Taklif yo\'q</h3><p>Yangi team taklifi shu yerda chiqadi.</p></div>';

      document.getElementById('list').innerHTML = data.notifications.length ? data.notifications.map((n) => {
        const href = notificationTarget(n);
        const read = !(n.unread || n.isRead === false);
        return `
          <button class="workspace-message-item notification-item ${read ? 'notification-read' : 'notification-unread'}" type="button" data-notification-id="${n.id}" ${href ? `data-href="${href}"` : ''}>
            <div class="workspace-record-top">
              <strong>${escapeHtml(n.content || n.text || 'Bildirishnoma')}</strong>
              <span class="notification-checks ${read ? 'is-read' : ''}">${notificationChecks(n)}</span>
            </div>
            <div class="text-xs muted">${escapeHtml(n.type || 'notification')} / ${fmtDate(n.createdAt)}</div>
            <span>${read ? "O'qilgan" : 'Yangi xabar'}</span>
          </button>
        `;
      }).join('') : '<div class="workspace-empty"><h3>Bildirishnoma yo\'q</h3><p>Yangi activity paydo bo\'lganda shu yerda ko\'rinadi.</p></div>';

      document.querySelectorAll('[data-accept-invite]').forEach((button) => {
        button.addEventListener('click', async () => {
          const inviteId = button.dataset.acceptInvite;
          const input = document.querySelector(`[data-secret-key="${inviteId}"]`);
          const errorBox = document.querySelector(`[data-invite-error="${inviteId}"]`);
          errorBox.className = 'text-sm muted feedback-error';
          errorBox.textContent = '';
          button.disabled = true;
          try {
            const result = await MllyCore.acceptWorkspaceInvite({
              inviteId,
              secretKey: input.value
            });
            await MllyCore.markNotificationsRead({ types: ['team_invite'], relatedEntityId: inviteId });
            errorBox.className = 'text-sm muted feedback-success';
            errorBox.textContent = 'Workspacega qo\'shildingiz.';
            setTimeout(() => { location.href = `team.html?id=${result.teamId}`; }, 600);
          } catch (error) {
            errorBox.textContent = error.message || 'Taklif qabul qilinmadi.';
            button.disabled = false;
          }
        });
      });

      document.querySelectorAll('[data-notification-id]').forEach((button) => {
        button.addEventListener('click', async () => {
          const notificationId = button.dataset.notificationId;
          const href = button.dataset.href || '';
          button.disabled = true;
          try {
            await MllyCore.markNotificationsRead({ ids: [notificationId] });
          } catch (_) {}
          if (href) {
            location.href = href;
            return;
          }
          button.disabled = false;
        });
      });
    }

    (async () => {
      const user = await window.MLLYCORE_AUTH_READY;
      if (!user) return;
      const data = await MllyCore.getDashboardData(user.uid).catch(() => ({ teams: [], ideas: [], notifications: [] }));
      window.__clearLoadingTimeout?.();
      mountLayout('notif', { profile: window.MLLYCORE_PROFILE, teams: data.teams, notifications: data.notifications });
      renderNotificationPage(data);

      // T49 — Smart Notification Batching (guruhlab ko'rsatish)
      const batchBtn = document.getElementById('batchToggleBtn');
      const batchView = document.getElementById('batchView');
      let batchOn = false;
      if (batchBtn && batchView) {
        batchBtn.addEventListener('click', async () => {
          batchOn = !batchOn;
          batchView.style.display = batchOn ? 'block' : 'none';
          batchBtn.classList.toggle('btn-primary', batchOn);
          batchBtn.classList.toggle('btn-secondary', !batchOn);
          if (!batchOn) { batchView.innerHTML = ''; return; }
          batchView.innerHTML = '<div class="muted">Yuklanmoqda...</div>';
          try {
            const r = await MllyCore.getNotificationDigest();
            const groups = r.groups || [];
            const total = r.total || 0;
            batchView.innerHTML = '<div class="batch-summary">Jami o‘qilmagan: <strong>' + total + '</strong></div>' + (groups.length ? '<div class="batch-list">' + groups.map((g) => `
              <div class="workspace-message-item batch-group">
                <div class="batch-group-head"><strong>${escapeHtml(g.type)}</strong> <span class="badge badge-progress">${g.count} ta</span></div>
                <div class="text-xs muted">${(g.sample || []).map((x) => escapeHtml((x.content || x.text || '').slice(0, 90))).join(' • ')}</div>
              </div>`).join('') + '</div>' : '<div class="muted">Guruhlanadigan bildirishnoma yo‘q</div>');
          } catch (e) { batchView.textContent = e.message; }
        });
      }

var _notifUnsub = null;
MllyCore.subscribeUserNotifications(user.uid, (notifications) => {
  const nextData = { ...data, notifications };
  window.APP_CONTEXT = { ...(window.APP_CONTEXT || {}), notifications };
  renderNotificationPage(nextData);
}).then(function(u) { _notifUnsub = u; }).catch(function() {});
window.addEventListener('pagehide', function() {
  if (_notifUnsub) { try { _notifUnsub(); } catch(_) {} _notifUnsub = null; }
});
    })();
  </script>
  <script>
    if ('serviceWorker' in navigator && location.protocol !== 'file:') {
      window.addEventListener('load', function() {
        navigator.serviceWorker.register('sw.js').catch(function(err) {
          console.warn('SW registration failed:', err);
        });
      });
    }
  </script>
</body>
</html>
