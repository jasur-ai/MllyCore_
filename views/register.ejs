<!DOCTYPE html>
<html lang="uz">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Ro'yxatdan o'tish - MllyCore</title>
  <link rel="icon" type="image/svg+xml" href="images/favicon.svg">
  <link rel="apple-touch-icon" href="images/favicon.svg">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <link rel="manifest" href="manifest.webmanifest">
  <meta name="theme-color" content="#0f172a">
  <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&family=Space+Grotesk:wght@500;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="css/styles.css">
  <script src="js/icons.js"></script>
  <script>(function(){try{var s=localStorage.getItem('mllycore-theme')||'dark';document.documentElement.className=s==='light'?'theme-light':'theme-dark'}catch(_){document.documentElement.className='theme-dark';}})();</script>
</head>
<body class="auth-page">
  <div class="auth-shell-pro">
    <div class="auth-shell-toolbar">
      <button type="button" class="btn btn-ghost btn-sm theme-toggle-btn" data-theme-toggle onclick="window.MllyCoreTheme?.toggle?.()"><span class="theme-glyph theme-sun" aria-hidden="true">&#9728;</span><span class="theme-glyph theme-moon" aria-hidden="true">&#9790;</span></button>
    </div>
    <aside class="auth-panel-side">
      <a href="index.html" class="auth-panel-brand">
        <span class="auth-panel-mark"><img src="images/logo-icon.svg" alt="M" width="32" height="34"></span>
        <span>
          <span class="auth-panel-name"><img src="images/logo-text.svg" alt="MllyCore" height="31" style="vertical-align:middle"></span>
          <span class="auth-panel-tag">Startup workspace onboarding</span>
        </span>
      </a>
      <div>
        <h1>Akkaunt yarating va private workspace oqimiga kiring.</h1>
        <p>Ro'yxatdan o'tishdan keyin email tasdiqlanadi, keyin sizga tegishli role bo'yicha ichki panel ochiladi.</p>
      </div>
      <div class="auth-feature-stack">
        <div class="auth-feature-card">
          <strong>Email verification majburiy</strong>
          <span>Tasdiqlanmaguncha dashboard va workspace ichiga kirilmaydi.</span>
        </div>
        <div class="auth-feature-card">
          <strong>Workspace privacy</strong>
          <span>Faqat siz a'zo bo'lgan workspace ichidagi ma'lumotlarni ko'rasiz.</span>
        </div>
        <div class="auth-feature-card">
          <strong>Role-based onboarding</strong>
          <span>Admin, team lead va member ko'rinishlari alohida boshqariladi.</span>
        </div>
      </div>
      <div class="auth-side-proof">
        <span>Private ideas</span>
        <span>Secret key flow</span>
        <span>Realtime collaboration</span>
      </div>
    </aside>

    <section class="auth-panel-main">
      <div class="auth-panel-card">
        <h2>Akkaunt yaratish</h2>
        <p>Bir necha qadamda MllyCore workspace tizimiga qo'shiling.</p>
        <form id="registerForm" class="workspace-form-grid" style="margin-top:20px">
          <div class="auth-grid-2">
            <div>
              <label class="label">Ism</label>
              <input class="input" id="firstName" required placeholder="Aziz">
            </div>
            <div>
              <label class="label">Familiya</label>
              <input class="input" id="lastName" required placeholder="Karimov">
            </div>
          </div>
          <div>
            <label class="label">Username</label>
            <input class="input" id="username" required placeholder="username">
          </div>
          <div>
            <label class="label">Email</label>
            <input class="input" id="email" type="email" required>
          </div>
          <div class="auth-grid-2">
            <div>
              <label class="label">Parol</label>
              <div class="password-field">
                <input class="input" id="password" type="password" required minlength="8" placeholder="kamida 8 ta belgi">
                <button type="button" class="password-toggle" data-target="password">Ko'rsat</button>
              </div>
            </div>
            <div>
              <label class="label">Parolni takrorlang</label>
              <div class="password-field">
                <input class="input" id="passwordConfirm" type="password" required minlength="8">
                <button type="button" class="password-toggle" data-target="passwordConfirm">Ko'rsat</button>
              </div>
            </div>
          </div>
          <label class="flex items-center gap-2 text-sm muted"><input type="checkbox" required> <span><a href="#" id="termsLink" style="color:#7dd3fc">Foydalanish shartlari</a>ga roziman</span></label>
          <button class="btn btn-primary w-full" type="submit">Ro'yxatdan o'tish</button>
          <p class="text-sm muted" id="authMessage" style="min-height:20px;margin:0"></p>
        </form>
        <div class="auth-helper">
          Akkauntingiz bormi? <a href="login.html">Kirish</a>
        </div>
      </div>
    </section>
  </div>

<div class="modal-backdrop" id="termsModal" onclick="if(event.target===this)this.classList.remove('open')">
  <div class="modal">
    <h3>Foydalanish shartlari</h3>
    <p class="modal-sub">MllyCore platformasidan foydalanish uchun quyidagi shartlarni qabul qiling.</p>

    <div class="terms-body">

      <p class="terms-label">1. WORKSPACE MAXFIYLIGI</p>
      <p class="text-sm">Har bir foydalanuvchi faqat o'zi a'zo bo'lgan workspace ma'lumotlarini ko'rishi mumkin. Boshqa workspace'lardagi g'oyalar, hujjatlar va ma'lumotlar mutlaqo yopiq va himoyalangan.</p>

      <p class="terms-label">2. G'OYALAR HIMOYASI</p>
      <p class="text-sm">Platforma ichida ulashilgan barcha g'oyalar, loyiha ma'lumotlari va muhokamalar workspace a'zolari uchun maxfiy saqlanadi. Ushbu ma'lumotlarni workspace tashqarisiga chiqarish, ulashish yoki tarqatish qat'iyan taqiqlanadi.</p>

      <p class="terms-label">3. TAQIQLAR</p>
      <p class="text-sm">Quyidagilar platformada mutlaqo taqiqlanadi:</p>
      <p class="text-sm">— Boshqa workspace ma'lumotlariga ruxsatsiz kirish urinishi</p>
      <p class="text-sm">— Zararli kontent, spam yoki aldamchi ma'lumot tarqatish</p>
      <p class="text-sm">— Boshqa foydalanuvchilar nomidan harakat qilish</p>
      <p class="text-sm">— Platforma tizimiga zarar yetkazishga urinish</p>

      <p class="terms-label">4. MA'LUMOTLAR HIMOYASI</p>
      <p class="text-sm">MllyCore foydalanuvchi shaxsiy ma'lumotlarini O'zbekiston Respublikasining shaxsiy ma'lumotlarni himoya qilish qonunchiligiga muvofiq saqlaydi va uchinchi shaxslarga foydalanuvchi rozilигисиз oshkor etmaydi.</p>

      <p class="terms-label">5. JAVOBGARLIK</p>
      <p class="text-sm">Ushbu shartlarni buzgan foydalanuvchining platformaga kirish huquqi to'xtatiladi. Yetkazilgan zarar uchun foydalanuvchi O'zbekiston Respublikasi qonunchiligiga muvofiq javob beradi.</p>

      <p class="text-sm muted" style="margin-top:14px">O'zbekiston Respublikasi FK 369–370-moddalari asosida.</p>

    </div>

    <label class="terms-check">
      <input type="checkbox" id="termsCheckbox" onchange="document.getElementById('termsAcceptBtn').disabled=!this.checked">
      <span class="text-sm">Ushbu shartlarni o'qidim va to'liq roziman</span>
    </label>

    <div class="modal-actions">
      <button class="btn btn-primary" id="termsAcceptBtn" disabled
        onclick="document.getElementById('termsModal').classList.remove('open')">
        Qabul qilaman
      </button>
    </div>
  </div>
</div>

   

  <script src="js/theme.js"></script>
  <script src="js/firebase-config.js"></script>
  <script src="js/firebase-service.js"></script>
  <script>
    document.getElementById('registerForm').addEventListener('submit', async (event) => {
      event.preventDefault();
      const message = document.getElementById('authMessage');
      const password = document.getElementById('password').value;
      const passwordConfirm = document.getElementById('passwordConfirm').value;
      message.className = 'text-sm muted feedback-error';

      if (password !== passwordConfirm) {
        message.textContent = 'Parollar bir xil emas.';
        return;
      }

      try {
        if (window.MLLYCORE_FIREBASE_ENABLED) {
          message.className = 'text-sm muted feedback-info';
          message.textContent = 'Akkaunt yaratilmoqda...';
          await window.MllyCore.register({
            firstName: document.getElementById('firstName').value.trim(),
            lastName: document.getElementById('lastName').value.trim(),
            username: document.getElementById('username').value.trim(),
            email: document.getElementById('email').value.trim(),
            password
          });
          message.className = 'text-sm muted feedback-success';
          message.textContent = "Ro'yxatdan o'tdingiz. Email tasdiqlash sahifasi ochilmoqda...";
        } else {
          message.className = 'text-sm muted feedback-error';
          message.textContent = 'Firebase sozlanmagan. Iltimos, administratorga murojaat qiling.';
          return;
        }
        setTimeout(() => { location.replace('verify-email.html'); }, 900);
      } catch (error) {
        message.className = 'text-sm muted feedback-error';
        message.textContent = friendlyAuthError(error, "Ro'yxatdan o'tishda xatolik yuz berdi.");
      }
    });

    function friendlyAuthError(error, fallback) {
      const code = error?.code || '';
      if (code === 'auth/email-already-in-use') return 'Bu email bilan akkaunt bor. Kirish sahifasidan foydalaning.';
      if (code === 'auth/weak-password') return "Parol kamida 8 ta belgidan iborat bo'lishi kerak.";
      if (code === 'auth/invalid-email') return "Email manzil noto'g'ri kiritilgan.";
      return error?.message || fallback;
    }

    document.querySelectorAll('.password-toggle').forEach((button) => {
      button.addEventListener('click', () => {
        const input = document.getElementById(button.dataset.target);
        const show = input.type === 'password';
        input.type = show ? 'text' : 'password';
        button.textContent = show ? 'Yashir' : "Ko'rsat";
      });
    });

    document.getElementById('termsLink').addEventListener('click', (event) => {
      event.preventDefault();
      document.getElementById('termsModal').classList.add('open');
    });
  </script>
  <script>
    if ('serviceWorker' in navigator && location.protocol !== 'file:') {
      window.addEventListener('load', function() {
        navigator.serviceWorker.register('sw.js').catch(function(err) {
          console.warn('SW registration failed:', err);
        });
      });
    }
  </script>
</body>
</html>
