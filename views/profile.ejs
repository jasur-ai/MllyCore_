<!DOCTYPE html>
<html lang="uz" class="auth-required">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Profil sozlamalari - MllyCore</title>
  <!-- Xavfsizlik: JS yuklanmasa ham 20 soniyadan keyin avtomatik qayta yuklash -->
  <link rel="icon" type="image/svg+xml" href="images/favicon.svg">
  <link rel="apple-touch-icon" href="images/favicon.svg">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <link rel="manifest" href="manifest.webmanifest">
  <meta name="theme-color" content="#0f172a">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="css/styles.css">
  
  <script>(function(){try{var s=localStorage.getItem('mllycore-theme')||'dark';document.documentElement.className=s==='light'?'theme-light':'theme-dark'}catch(_){document.documentElement.className='theme-dark';}})();</script>
</head>
<body>
  <a href="#app" class="skip-link">Asosiy kontentga o'tish</a>
  <div id="app">
    <div class="workspace-app">
      <section class="workspace-command">
        <div>
          <h1 class="workspace-command-title">Profile & security</h1>
          <p class="workspace-command-copy">Akkaunt ma'lumotlari, email tasdiqlash va parol xavfsizligi shu yerda boshqariladi.</p>
        </div>
      </section>

              <div class="ws-tabs" role="tablist" aria-label="Profil bo'limlari" style="margin-bottom:0;border-bottom:none;">
        <button type="button" class="ws-tab" role="tab" data-tab="shaxsiy" aria-selected="true" id="tab-shaxsiy">👤 Shaxsiy</button>
        <button type="button" class="ws-tab" role="tab" data-tab="ish" aria-selected="false" id="tab-ish">⚙️ Ish sozlamalari</button>
        <button type="button" class="ws-tab" role="tab" data-tab="malumotlar" aria-selected="false" id="tab-malumotlar">📊 Ma'lumotlarim</button>
      </div>
      <div class="ws-tab-panels" style="margin-top:20px;">

        <div class="ws-tab-panel" data-panel="shaxsiy" role="tabpanel" aria-labelledby="tab-shaxsiy">
          <div class="workspace-layout">
            <div class="workspace-main-stack">
              <div class="workspace-surface pad">
                <div class="section-head"><h2>👤 Shaxsiy ma'lumotlar</h2></div>
                <div class="workspace-form-grid">
                  <div>
                    <label class="label">Ism</label>
                    <input class="input" id="name" placeholder="Ismingizni kiriting">
                  </div>
                  <div>
                    <label class="label">Username</label>
                    <input class="input" id="username" placeholder="username">
                  </div>
                  <div>
                    <label class="label">Email</label>
                    <input class="input" id="email" disabled>
                  </div>
                  <button class="btn btn-primary" id="saveProfileBtn">💾 Saqlash</button>
                </div>
              </div>

              <div class="workspace-surface pad" id="twoFactorPanel">
                <div class="section-head"><h2>🔐 Ikki bosqichli tasdiqlash (2FA)</h2></div>
                <p class="muted text-sm">Shaxsiy hisobingizni TOTP (Google Authenticator / Authy) orqali qo'shimcha himoyalang.</p>
                <p class="muted text-sm" style="margin-top:6px"><strong>Qanday faollashtirish:</strong> "2FA ni yoqish" tugmasini bosing → ekranga chiqadigan <strong>secret key</strong> ni autentifikator ilovasiga kiriting yoki QR kodni skan qiling → 6 xonali kodni kiritib "Tasdiqlash" bosing. <span class="modal-secret-warn">Secret key faqat bir marta ko'rsatiladi — uni saqlab oling va hech kimga bermang.</span></p>
                <div id="twoFactorStatus" class="text-sm muted" style="margin:8px 0;"></div>
                <div id="twoFactorSetup" style="display:none;margin-bottom:12px;">
                  <div class="text-sm">1. Secret ni autentifikatorga kiriting yoki QR ochang:</div>
                  <div class="modal-secret-warn">⚠️ Bu secret faqat bir marta ko'rsatiladi — uni saqlab oling va hech kimga bermang. Tasdiqlangandan keyin o'chib ketadi.</div>
                  <div class="modal-secret-value">
                    <code id="twoFactorSecret" style="word-break:break-all;background:var(--surface-sub);padding:8px;border-radius:8px;"></code>
                    <button type="button" class="btn btn-secondary btn-sm" id="copyTwoFactorSecret">Copy</button>
                  </div>
                  <a id="twoFactorOtpauth" class="btn btn-tertiary btn-sm" target="_blank" rel="noopener">QR ochish</a>
                  <div class="workspace-form-grid" style="margin-top:10px;">
                    <input class="input" id="twoFactorCode" placeholder="6 xonali kod">
                    <button class="btn btn-primary" id="twoFactorVerifyBtn">Tasdiqlash</button>
                  </div>
                </div>
                <div class="workspace-form-actions" style="justify-content:flex-start;">
                  <button class="btn btn-primary" id="twoFactorEnableBtn">2FA ni yoqish</button>
                  <button class="btn btn-danger" id="twoFactorDisableBtn" style="display:none;">2FA ni o'chirish</button>
                </div>
              </div>
            </div>

            <aside class="workspace-side-stack">
              <div class="workspace-surface pad" style="position:relative;overflow:hidden;">
                <div style="position:absolute;top:-20px;right:-20px;font-size:80px;opacity:0.06;pointer-events:none;user-select:none;">🔑</div>
                <h3 style="margin:0 0 12px;display:flex;align-items:center;gap:8px;font-size:15px;">🔑 Parolni yangilash</h3>
                <p class="muted text-sm" style="margin:0 0 14px;line-height:1.6;">Hisobingiz xavfsizligi uchun parolingizni muntazam yangilab turing. <span style="color:var(--accent);">Kamida 6 ta belgi</span> dan iborat bo'lishi kerak.</p>
                <div class="workspace-form-stack">
                  <div class="input-group" style="display:flex;flex-direction:column;gap:4px;">
                    <label class="label" style="font-size:12px;opacity:0.8;">Hozirgi parol</label>
                    <div style="position:relative;">
                      <span style="position:absolute;left:12px;top:50%;transform:translateY(-50%);opacity:0.4;font-size:14px;pointer-events:none;">🔒</span>
                      <input class="input" id="currentPassword" type="password" autocomplete="current-password" placeholder="Joriy parolni kiriting" style="padding-left:36px;">
                    </div>
                  </div>
                  <div class="input-group" style="display:flex;flex-direction:column;gap:4px;">
                    <label class="label" style="font-size:12px;opacity:0.8;">Yangi parol</label>
                    <div style="position:relative;">
                      <span style="position:absolute;left:12px;top:50%;transform:translateY(-50%);opacity:0.4;font-size:14px;pointer-events:none;">🔐</span>
                      <input class="input" id="newPassword" type="password" autocomplete="new-password" placeholder="Kamida 6 belgi" style="padding-left:36px;">
                    </div>
                  </div>
                  <div class="input-group" style="display:flex;flex-direction:column;gap:4px;">
                    <label class="label" style="font-size:12px;opacity:0.8;">Yangi parolni takrorlang</label>
                    <div style="position:relative;">
                      <span style="position:absolute;left:12px;top:50%;transform:translateY(-50%);opacity:0.4;font-size:14px;pointer-events:none;">🔐</span>
                      <input class="input" id="confirmPassword" type="password" autocomplete="new-password" placeholder="Yangi parolni qayta kiriting" style="padding-left:36px;">
                    </div>
                  </div>
                  <button class="btn btn-primary w-full" id="changePasswordBtn" style="margin-top:4px;">Parolni almashtirish</button>
                  <button class="btn btn-tertiary w-full" id="resetPasswordBtn" style="font-size:13px;">📧 Email orqali link yuborish</button>
                </div>
              </div>
              <div class="workspace-surface pad" style="background:linear-gradient(135deg, rgba(59,130,246,0.08), rgba(99,102,241,0.04));border-color:rgba(59,130,246,0.2);position:relative;overflow:hidden;">
                <div style="position:absolute;top:-10px;right:-10px;font-size:50px;opacity:0.08;pointer-events:none;user-select:none;">🛡️</div>
                <h3 style="margin:0 0 6px;display:flex;align-items:center;gap:6px;font-size:13px;color:var(--accent);">🛡️ Xavfsizlik eslatmasi</h3>
                <p class="muted text-sm" style="margin:0;line-height:1.6;font-size:12px;">Email orqali parolni tiklash linki <strong>Firebase Authentication</strong> tomonidan xavfsiz tarzda yuboriladi. Profil o'zgarishlari barcha sessiyalarda qayta yuklanadi.</p>
              </div>
            </aside>
          </div>
        </div>

        <div class="ws-tab-panel" data-panel="ish" role="tabpanel" aria-labelledby="tab-ish" hidden>
          <div class="workspace-layout">
            <div class="workspace-main-stack">
              <div class="workspace-surface pad">
                <div class="section-head"><h2>⏰ Ish vaqti va bildirishnomalar</h2></div>
                <div class="workspace-form-grid">
                  <div>
                    <label class="label">Ish boshlanishi</label>
                    <input class="input" id="workingHoursStart" type="time" placeholder="09:00">
                  </div>
                  <div>
                    <label class="label">Ish tugashi</label>
                    <input class="input" id="workingHoursEnd" type="time" placeholder="18:00">
                  </div>
                  <div>
                    <label class="label">Vaqt mintaqasi</label>
                    <select class="input" id="timezone">
                      <option value="UTC">UTC</option>
                      <option value="Asia/Tashkent">Asia/Tashkent (+5)</option>
                      <option value="Asia/Almaty">Asia/Almaty (+6)</option>
                      <option value="Europe/Istanbul">Europe/Istanbul (+3)</option>
                      <option value="Europe/Moscow">Europe/Moscow (+3)</option>
                      <option value="America/New_York">America/New_York (-5)</option>
                    </select>
                  </div>
                  <div>
                    <label class="label">Email digest</label>
                    <select class="input" id="emailDigestFrequency">
                      <option value="off">O'chirilgan</option>
                      <option value="daily">Har kuni</option>
                      <option value="weekly">Haftada bir marta</option>
                    </select>
                  </div>
                  <div>
                    <label class="label">Telegram username</label>
                    <input class="input" id="telegramUsername" placeholder="@username">
                  </div>
                  <button class="btn btn-primary" id="savePreferencesBtn">💾 Sozlamalarni saqlash</button>
                </div>
              </div>

              <div class="workspace-surface pad" id="extraProfilePanel">
                <div class="section-head"><h2>🔧 Qo'shimcha sozlamalar</h2></div>
                <div class="workspace-form-stack">
                  <div class="extra-setting" style="border-color:rgba(59,130,246,0.20);">
                    <div style="display:flex;align-items:center;gap:8px;margin-bottom:4px;">
                      <span style="font-size:18px;">🤖</span>
                      <strong>Telegram bot</strong>
                      <span class="badge badge-active" id="telegramLinkStatus">Ulanish mavjud emas</span>
                    </div>
                    <p class="muted text-xs" style="margin:0 0 8px;">
                      Bot orqali bildirishnomalarni Telegram'da oling. 
                      <code>@MllyCoreBot</code> ga <strong>/start</strong> yozing — yangi usul!
                    </p>
                    <div style="display:flex;gap:8px;align-items:center;flex-wrap:wrap;">
                      <button class="btn btn-primary btn-sm" id="generateTelegramCodeBtn" style="white-space:nowrap;">🔑 Kod olish</button>
                      <span class="muted text-xs">yoki eski usul:</span>
                      <input class="input" id="telegramChatId" placeholder="Chat ID" style="max-width:180px;">
                      <button class="btn btn-secondary btn-sm" id="linkTelegramBtn" style="white-space:nowrap;">✅ Ulash</button>
                    </div>
                    <div id="telegramCodeDisplay" style="display:none;margin-top:10px;padding:14px;background:var(--surface-sub);border:1px solid var(--line);border-radius:10px;text-align:center;">
                      <div class="text-sm muted" style="margin-bottom:8px;">15 daqiqa ichida Telegram'da <code>@MllyCoreBot</code> ga quyidagi kodni yuboring:</div>
                      <div style="font-size:28px;font-weight:800;font-family:'Space Grotesk',monospace;letter-spacing:6px;color:var(--accent);padding:12px;background:var(--bg);border-radius:8px;display:inline-block;" id="telegramCodeValue">------</div>
                      <div class="text-xs muted" style="margin-top:8px;">Kodni nusxalash uchun ustiga bosing</div>
                    </div>
                  </div>
                  <div class="extra-setting">
                    <div style="display:flex;align-items:center;gap:8px;margin-bottom:4px;">
                      <span style="font-size:18px;">🧠</span>
                      <strong>Ko'nikmalar</strong>
                    </div>
                    <p class="muted text-xs" style="margin:0 0 8px;">Ko'nikmalaringizni vergul bilan ajrating. Vazifa moslashida foydalaniladi.</p>
                    <div style="display:flex;gap:8px;align-items:center;">
                      <input class="input" id="skillsInput" placeholder="React, Figma, Marketing" style="flex:1;">
                      <button class="btn btn-primary btn-sm" id="saveSkillsBtn">💾 Saqlash</button>
                    </div>
                  </div>
                  <div class="extra-setting">
                    <div style="display:flex;align-items:center;gap:8px;margin-bottom:4px;">
                      <span style="font-size:18px;">🌐</span>
                      <strong>Interfeys tili</strong>
                    </div>
                    <div style="display:flex;gap:8px;align-items:center;">
                      <select class="input" id="localeSelect" style="flex:1;">
                        <option value="uz">O'zbekcha</option>
                        <option value="ru">Русский</option>
                        <option value="en">English</option>
                      </select>
                      <button class="btn btn-primary btn-sm" id="saveLocaleBtn">💾 Saqlash</button>
                    </div>
                  </div>
                </div>
              </div>
            </div>

            <aside class="workspace-side-stack">
              <div class="workspace-surface pad">
                <h3 style="margin:0 0 12px;display:flex;align-items:center;gap:6px;">🐙 GitHub ulanishi</h3>
                <p class="muted text-sm" style="margin:0 0 10px">Vazifani GitHub Issue ga aylantirish uchun vazifa kartasidagi 🐙 GitHub'ga tugmasidan foydalaning.</p>
                <p class="muted text-xs" style="margin:0">Repo nomi <code>user/repo</code> ko'rinishida kiritiladi.</p>
              </div>
              <div class="workspace-surface pad" style="background:rgba(34,197,94,0.06);border-color:rgba(34,197,94,0.18);">
                <h3 style="margin:0 0 8px;display:flex;align-items:center;gap:6px;">📋 Sozlamalar haqida</h3>
                <p class="muted text-sm" style="margin:0;line-height:1.7;">Bu bo'limdagi sozlamalar faqat sizning hisobingizga ta'sir qiladi. Ish vaqti va bildirishnoma sozlamalari quiet hours va digest xabarlarida ishlatiladi.</p>
              </div>
            </aside>
          </div>
        </div>

        <div class="ws-tab-panel" data-panel="malumotlar" role="tabpanel" aria-labelledby="tab-malumotlar" hidden>
          <div class="workspace-layout">
            <div class="workspace-main-stack">
              <div class="workspace-surface" id="personalStatsSurface">
                <div class="workspace-surface-head">
                  <div>
                    <h2>📊 Shaxsiy statistika</h2>
                    <div class="workspace-surface-copy">Shaxsiy faoliyat va performance metrikalari.</div>
                  </div>
                </div>
                <div id="personalStatsContainer" style="padding:16px;display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:16px;"></div>
              </div>

              <div class="workspace-surface">
                <div class="workspace-surface-head">
                  <div>
                    <h2>📋 Cross-Workspace Overview</h2>
                    <div class="workspace-surface-copy">Siz a'zo bo'lgan barcha workspace'lardagi shaxsiy umumlashma.</div>
                  </div>
                </div>
                <div id="myOverviewContainer" style="padding:16px;display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:12px;"></div>
              </div>
            </div>

            <aside class="workspace-side-stack">
              <div class="workspace-surface pad">
                <h3 style="margin:0 0 12px;display:flex;align-items:center;gap:6px;">📥 Ma'lumotlarni eksport qilish</h3>
                <p class="muted text-sm" style="margin:0 0 12px">Barcha shaxsiy ma'lumotlaringizni JSON formatida yuklab oling.</p>
                <button class="btn btn-primary w-full" onclick="window.exportMyData()">📦 Ma'lumotlarni yuklab olish</button>
              </div>
              <div class="workspace-surface pad" style="background:rgba(245,158,11,0.06);border-color:rgba(245,158,11,0.18);">
                <h3 style="margin:0 0 8px;display:flex;align-items:center;gap:6px;">📌 Eslatma</h3>
                <p class="muted text-sm" style="margin:0;line-height:1.7;">Statistika ma'lumotlari har bir workspace bo'yicha alohida hisoblanadi. Yangi workspace qo'shilganda avtomatik yangilanadi.</p>
              </div>
            </aside>
          </div>
        </div>

      </div>

    </div>
  </div>
  <script src="js/theme.js"></script>
  <script src="js/firebase-config.js"></script>
  
  <script src="js/firebase-service.js"></script>
  <script src="js/auth-guard.js"></script>
  <script src="js/layout.js"></script>
  <script src="js/analytics-widgets.js"></script>
  <script>
    // JavaScript ishlayapti — meta refreshni to'xtatamiz
    (function() {
      var meta = document.getElementById('metaHardTimeout');
      if (meta) { meta.content = ''; if (meta.parentNode) meta.parentNode.removeChild(meta); }
    })();
    // retry=1 bilan qayta yuklanganda — to'g'ridan-to'g'ri xato ko'rsatamiz
    if (location.search.indexOf('retry=1') !== -1) {
      document.getElementById('app').innerHTML = '<div class="workspace-app" style="display:flex;flex-direction:column;align-items:center;justify-content:center;min-height:60vh"><div class="workspace-empty"><h3>Yuklashda vaqt o\'tdi</h3><p>Sahifa avtomatik qayta yuklandi, ammo ma\'lumotlarni yuklashda davomiy muammo bor. Internet aloqangizni tekshiring.</p><button class="btn btn-primary" onclick="location.href=\'profile.html\'">🔄 Qayta urinish</button></div></div>';
    }

    // Xavfsizlik: 15 soniya ichida ma'lumotlar yuklanmasa, xato xabarini ko'rsatamiz
    window.__mllyLoadingTimeout = setTimeout(() => {
      var nameInput = document.getElementById('name');
      // Agar `#name` inputi hali to'ldirilmagan bo'lsa → ma'lumot yuklanmagan
      if (nameInput && !nameInput.value) {
        document.getElementById('app').innerHTML = '<div class="workspace-app" style="display:flex;flex-direction:column;align-items:center;justify-content:center;min-height:60vh"><div class="workspace-empty"><h3>Yuklashda xatolik</h3><p>Ma\'lumotlarni yuklash uzoq vaqt oldi. Internet aloqangizni tekshiring yoki qayta urinib ko\'ring.</p></div></div>';
      }
    }, 15000);
    window.__clearLoadingTimeout = () => {
      if (window.__mllyLoadingTimeout) {
        clearTimeout(window.__mllyLoadingTimeout);
        window.__mllyLoadingTimeout = null;
      }
    };

    window.UTIL = window.UTIL || { toast: (msg) => alert(msg) };
    
    // Xavfsizlik: 15 soniya ichida yuklanmasa, xato xabarini ko'rsatamiz
    window.__mllyLoadingTimeout = setTimeout(() => {
      var appEl = document.getElementById('app');
      if (!appEl || appEl.classList.contains('app')) return;
      appEl.innerHTML = '<div class="workspace-app" style="display:flex;flex-direction:column;align-items:center;justify-content:center;min-height:60vh"><div class="workspace-empty"><h3>Yuklashda xatolik</h3><p>Profil ma\'lumotlarini yuklash uzoq vaqt oldi. Internet aloqangizni tekshiring yoki qayta urinib ko\'ring.</p><button class="btn btn-primary btn-sm" onclick="location.reload()">🔄 Qayta urinish</button></div></div>';
    }, 15000);
    window.__clearLoadingTimeout = () => { if (window.__mllyLoadingTimeout) { clearTimeout(window.__mllyLoadingTimeout); window.__mllyLoadingTimeout = null; } };

    (async () => {
      const user = await window.MLLYCORE_AUTH_READY;
      if (!user) return;
      window.__clearLoadingTimeout?.();
      const profile = window.MLLYCORE_PROFILE;
      // FIX (complaint 7): profilga o'tganda "Workspace'larim" yo'qolmasligi uchun
      // haqiqiy jamoalar ro'yxatini yuklab, sidebar ga uzatamiz.
      let dash = { teams: [], notifications: [] };
      try { dash = await MllyCore.getDashboardData(user.uid); } catch (_) {}
      window.__clearLoadingTimeout?.();
      mountLayout('profile', { profile, teams: dash.teams || [], notifications: dash.notifications || [] });
      document.getElementById('name').value = profile.name || '';
      document.getElementById('username').value = profile.username || '';
      document.getElementById('email').value = profile.email || user.email || '';

      // Admin/Manager uchun o'z "Shaxsiy statistikasi" kerak emas — ular user/lead/team
      // statistikasini admin paneli orqali ko'radi. Shuning uchun bu bo'limni yashiryamiz.
      if (profile && (profile.role === 'admin' || profile.role === 'manager')) {
        const psSurface = document.getElementById('personalStatsSurface');
        if (psSurface) psSurface.style.display = 'none';
      }

      // Load Personal Statistics
      (async () => {
        try {
          const idToken = await user.getIdToken();
          const response = await fetch('/api/index?action=member-stats', {
            headers: { 'Authorization': `Bearer ${idToken}` }
          });
          const data = await response.json();
          if (data.personalStats) {
            const container = document.getElementById('personalStatsContainer');
            container.innerHTML = `
              ${window.AnalyticsWidgets.renderStatCard('Bajarilgan Vazifalar', data.personalStats.completedTasks || 0, 'Bu oy', '🟢')}
              ${window.AnalyticsWidgets.renderStatCard('Jami Vazifalar', data.personalStats.totalTasks || 0, 'Biriktirilgan', '📋')}
              ${window.AnalyticsWidgets.renderStatCard('Yaratilgan G\'oyalar', data.personalStats.ideasCreated || 0, 'Jami', '💡')}
              ${window.AnalyticsWidgets.renderStatCard('Ball', data.score || 0, 'Gamifikatsiya', '🏅')}
            `;
          }
        } catch (error) {
          console.error('Personal statistika olishda xatolik:', error);
        }
      })();

      // ===== T15 Cross-Workspace Overview + T7 Export My Data =====
      window.loadMyOverview = async () => {
        try {
          const data = await MllyCore.getMyOverview();
          const container = document.getElementById('myOverviewContainer');
          if (!data.overview || !data.overview.length) {
            container.innerHTML = '<div class="muted text-sm">Hozircha workspace\'lar yoq.</div>';
            return;
          }
          container.innerHTML = data.overview.map(o => `
            <div style="background:var(--surface-sub);border:1px solid var(--line);border-radius:12px;padding:14px;">
              <div style="font-weight:600;margin-bottom:8px;display:flex;align-items:center;justify-content:space-between;gap:8px;">
                <span>${o.teamName || o.teamId}</span>
                <span class="badge ${o.role === 'team_lead' ? 'badge-active' : ''}">${o.role || 'member'}</span>
              </div>
              <div class="text-sm">🟢 Ochiq vazifalar: <b>${o.openTasks}</b></div>
              <div class="text-sm">✅ Bajarilgan: <b>${o.completedTasks}</b></div>
              <div class="text-sm">💡 Mening g'oyalarim: <b>${o.myIdeas}</b></div>
              <div class="text-sm">🔔 O'qilmagan: <b>${o.unreadNotifications}</b></div>
              <a class="btn btn-tertiary btn-sm" style="margin-top:10px" href="team.html?id=${encodeURIComponent(o.teamId)}">Ochish</a>
            </div>
          `).join('');
        } catch (e) { console.error('Overview', e); }
      };
      window.exportMyData = async () => {
        try {
          const data = await MllyCore.exportMyData();
          if (data.data) {
            const bin = atob(data.data);
            const bytes = new Uint8Array(bin.length);
            for (let i = 0; i < bin.length; i += 1) bytes[i] = bin.charCodeAt(i);
            const text = new TextDecoder('utf-8').decode(bytes);
            const blob = new Blob([text], { type: 'application/json' });
            const a = document.createElement('a');
            a.href = URL.createObjectURL(blob);
            a.download = data.fileName || 'my-data.json';
            a.click();
          }
        } catch (e) { UTIL.toast(e.message); }
      };
      window.loadMyOverview();

      // Load User Preferences — getCollection o'rniga getUserProfile (getDoc) ishlatiladi,
      // chunki non-admin userlar users kolleksiyasini list qila olmaydi (security rules).
      (async () => {
        try {
          const userDoc = await MllyCore.getUserProfile(user.uid);
          if (userDoc) {
            if (userDoc.workingHours) {
              document.getElementById('workingHoursStart').value = userDoc.workingHours.start || '09:00';
              document.getElementById('workingHoursEnd').value = userDoc.workingHours.end || '18:00';
            }
            if (userDoc.timezone) document.getElementById('timezone').value = userDoc.timezone;
            if (userDoc.emailDigestFrequency) document.getElementById('emailDigestFrequency').value = userDoc.emailDigestFrequency;
            if (userDoc.telegramUsername) document.getElementById('telegramUsername').value = userDoc.telegramUsername;
          }
        } catch (error) {
          console.error('Preferences yuklashda xatolik:', error);
        }
      })();

      // ===== T3 Admin 2FA =====
      (async () => {
        const panel = document.getElementById('twoFactorPanel');
        const statusEl = document.getElementById('twoFactorStatus');
        const setupEl = document.getElementById('twoFactorSetup');
        const enableBtn = document.getElementById('twoFactorEnableBtn');
        const disableBtn = document.getElementById('twoFactorDisableBtn');
        const verifyBtn = document.getElementById('twoFactorVerifyBtn');
        if (!panel) return;
        let enabled = false;
        try {
          const me = await MllyCore.getUserProfile(user.uid);
          enabled = !!(me && me.twoFactorEnabled);
        } catch (_) {}
        const render = () => {
          if (enabled) {
            statusEl.textContent = "✅ 2FA yoqilgan. Workspace o'chirishda kod talab qilinadi.";
            setupEl.style.display = 'none';
            // 9-bo'lim: sezgir secret sahifa xotirasidan tozalanadi (setup yopilganda).
            const sec = document.getElementById('twoFactorSecret');
            if (sec) sec.textContent = '';
            const otp = document.getElementById('twoFactorOtpauth');
            if (otp) otp.removeAttribute('href');
            enableBtn.style.display = 'none';
            disableBtn.style.display = '';
          } else {
            statusEl.textContent = "2FA o'chirilgan.";
            enableBtn.style.display = '';
            disableBtn.style.display = 'none';
          }
        };
        render();
        enableBtn?.addEventListener('click', async () => {
          try {
            const res = await MllyCore.enable2FA();
            document.getElementById('twoFactorSecret').textContent = res.secret || '';
            const otp = document.getElementById('twoFactorOtpauth');
            if (otp && res.otpauth) otp.href = res.otpauth;
            setupEl.style.display = 'block';
          } catch (e) { UTIL.toast(e.message); }
        });
        verifyBtn?.addEventListener('click', async () => {
          const code = document.getElementById('twoFactorCode').value;
          try {
            await MllyCore.verify2FA(code);
            enabled = true; render();
            UTIL.toast('2FA yoqildi.');
          } catch (e) { UTIL.toast(e.message); }
        });
        disableBtn?.addEventListener('click', async () => {
          const code = window.prompt('2FA kodni kiriting:');
          if (!code) return;
          try {
            await MllyCore.disable2FA(code);
            enabled = false; render();
            UTIL.toast("2FA o'chirildi.");
          } catch (e) { UTIL.toast(e.message); }
        });
        // 9-bo'lim: secret ni nusxalash (clipboard) — modal-secret qoidasiga muvofiq.
        document.getElementById('copyTwoFactorSecret')?.addEventListener('click', async () => {
          const sec = document.getElementById('twoFactorSecret');
          if (!sec || !sec.textContent) return;
          try { await navigator.clipboard.writeText(sec.textContent); UTIL.toast('Secret nusxalandi'); }
          catch (_) { UTIL.toast('Nusxalab bo‘lmadi'); }
        });
      })();

      // ===== T22 / T25 / T33 qo'shimcha profil sozlamalari =====
      (async () => {
        try {
          const me = await MllyCore.getUserProfile(user.uid);
          if (me) {
            if (me.telegramChatId) {
              document.getElementById('telegramChatId').value = me.telegramChatId;
              document.getElementById('telegramLinkStatus').textContent = '✅ Ulangan';
              document.getElementById('telegramLinkStatus').className = 'badge badge-active';
            }
            if (Array.isArray(me.skills)) document.getElementById('skillsInput').value = me.skills.join(', ');
            if (me.locale) document.getElementById('localeSelect').value = me.locale;
          }
        } catch (_) {}
        document.getElementById('linkTelegramBtn')?.addEventListener('click', async () => {
          const v = document.getElementById('telegramChatId').value.trim();
          if (!v) return UTIL.toast('Chat ID kiriting');
          try { await MllyCore.linkTelegram(v); document.getElementById('telegramLinkStatus').textContent = '✅ Ulangan'; document.getElementById('telegramLinkStatus').className = 'badge badge-active'; UTIL.toast('Telegram ulandi'); } catch (e) { UTIL.toast(e.message); }
        });
        document.getElementById('generateTelegramCodeBtn')?.addEventListener('click', async function() {
          const btn = this;
          btn.disabled = true;
          btn.textContent = '⏳ Yuklanmoqda...';
          try {
            const idToken = await user.getIdToken();
            const resp = await fetch('/api/index?action=generate-telegram-code', {
              headers: { 'Authorization': 'Bearer ' + idToken },
              method: 'POST'
            });
            const data = await resp.json();
            if (data.success && data.code) {
              const display = document.getElementById('telegramCodeDisplay');
              const value = document.getElementById('telegramCodeValue');
              value.textContent = data.code;
              display.style.display = 'block';
              try { await navigator.clipboard.writeText(data.code); } catch (_) {}
              UTIL.toast('Kod yaratildi va nusxalandi! Telegram botga /start ' + data.code + ' yozing.');
            } else {
              UTIL.toast(data.error || 'Kod olishda xatolik');
            }
          } catch (e) {
            UTIL.toast(e.message || 'Kod olishda xatolik');
          } finally {
            btn.disabled = false;
            btn.textContent = '🔑 Kod olish';
          }
        });
        // Kodni bosganda nusxalash
        document.getElementById('telegramCodeValue')?.addEventListener('click', async function() {
          if (this.textContent === '------') return;
          try {
            await navigator.clipboard.writeText(this.textContent);
            UTIL.toast('Kod nusxalandi');
          } catch (_) {}
        });
        document.getElementById('saveSkillsBtn')?.addEventListener('click', async () => {
          const v = document.getElementById('skillsInput').value.split(',').map((s) => s.trim()).filter(Boolean);
          try { await MllyCore.updateSkills(v); UTIL.toast("Ko'nikmalar saqlandi"); } catch (e) { UTIL.toast(e.message); }
        });
        document.getElementById('saveLocaleBtn')?.addEventListener('click', async () => {
          const v = document.getElementById('localeSelect').value;
          try { await MllyCore.updateLocale(v); UTIL.toast('Til saqlandi'); } catch (e) { UTIL.toast(e.message); }
        });
      })();

      document.getElementById('saveProfileBtn').addEventListener('click', async () => {
        try {
          await MllyCore.updateUserProfile({
            name: document.getElementById('name').value,
            username: document.getElementById('username').value
          });
          UTIL.toast('Profil saqlandi');
        } catch (error) {
          UTIL.toast(error.message || 'Profil saqlanmadi');
        }
      });

      document.getElementById('savePreferencesBtn').addEventListener('click', async () => {
        try {
          const idToken = await user.getIdToken();
          const start = document.getElementById('workingHoursStart').value;
          const end = document.getElementById('workingHoursEnd').value;
          const response = await fetch('/api/index?action=update-preferences', {
            method: 'POST',
            headers: {
              'Authorization': `Bearer ${idToken}`,
              'Content-Type': 'application/json'
            },
            body: JSON.stringify({
              workingHours: start && end ? { start, end } : null,
              timezone: document.getElementById('timezone').value,
              emailDigestFrequency: document.getElementById('emailDigestFrequency').value,
              telegramUsername: document.getElementById('telegramUsername').value || null
            })
          });
          const data = await response.json();
          if (data.success) {
            UTIL.toast('Sozlamalar saqlandi');
          } else {
            UTIL.toast(data.error || 'Sozlamalar saqlanmadi');
          }
        } catch (error) {
          UTIL.toast(error.message || 'Sozlamalar saqlanmadi');
        }
      });

      document.getElementById('changePasswordBtn').addEventListener('click', async () => {
        const currentPassword = document.getElementById('currentPassword').value;
        const newPassword = document.getElementById('newPassword').value;
        const confirmPassword = document.getElementById('confirmPassword').value;
        if (newPassword !== confirmPassword) {
          UTIL.toast('Yangi parol takrori mos emas');
          return;
        }
        try {
          await MllyCore.changePassword({ currentPassword, newPassword });
          document.getElementById('currentPassword').value = '';
          document.getElementById('newPassword').value = '';
          document.getElementById('confirmPassword').value = '';
          UTIL.toast('Parol almashtirildi');
        } catch (error) {
          UTIL.toast(error.message || 'Parol almashtirilmadi');
        }
      });

      document.getElementById('resetPasswordBtn').addEventListener('click', async () => {
        try {
          await MllyCore.sendPasswordReset();
          UTIL.toast('Firebase parol tiklash linkini emailingizga yubordi');
        } catch (error) {
          UTIL.toast(error.message || 'Parol tiklash xati yuborilmadi');
        }
      });

      // T-UI — Profil sahifasi tablari (Shaxsiy / Ish sozlamalari / Ma'lumotlarim)
      (() => {
        const tabs = Array.from(document.querySelectorAll('.ws-tab'));
        const panels = Array.from(document.querySelectorAll('.ws-tab-panel'));
        if (!tabs.length) return;
        const key = 'mlly_profile_tab';
        const activate = (name) => {
          tabs.forEach((t) => t.setAttribute('aria-selected', String(t.dataset.tab === name)));
          panels.forEach((p) => { p.hidden = (p.dataset.panel !== name); });
          try { localStorage.setItem(key, name); } catch (_) {}
        };
        tabs.forEach((t) => t.addEventListener('click', () => activate(t.dataset.tab)));
        const tablist = document.querySelector('.ws-tabs');
        tablist?.addEventListener('keydown', (e) => {
          if (e.key !== 'ArrowRight' && e.key !== 'ArrowLeft') return;
          const i = tabs.indexOf(document.activeElement);
          if (i < 0) return;
          const next = e.key === 'ArrowRight' ? (i + 1) % tabs.length : (i - 1 + tabs.length) % tabs.length;
          tabs[next].focus(); tabs[next].click();
          e.preventDefault();
        });
        try { const s = localStorage.getItem(key); if (tabs.some((t) => t.dataset.tab === s)) activate(s); } catch (_) {}
      })();
    })();
  </script>
  <script>
    if ('serviceWorker' in navigator && location.protocol !== 'file:') {
      window.addEventListener('load', function() {
        navigator.serviceWorker.register('sw.js').catch(function(err) {
          console.warn('SW registration failed:', err);
        });
      });
    }
  </script>
</body>
</html>
